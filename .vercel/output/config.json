{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/agricultura/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/aviso-legal/?$",
			"dest": "_render"
		},
		{
			"src": "^/contacto/?$",
			"dest": "_render"
		},
		{
			"src": "^/ganaderia/?$",
			"dest": "_render"
		},
		{
			"src": "^/politicas-cookies/?$",
			"dest": "_render"
		},
		{
			"src": "^/privacidad/?$",
			"dest": "_render"
		},
		{
			"src": "^/quienes-somos/?$",
			"dest": "_render"
		},
		{
			"src": "^/servicios/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		}
	]
}