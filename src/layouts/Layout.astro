---
import "../styles/global.css";
import SeoHead from "../components/layouts/SeoHead.astro";
import SiteHeader from "../components/layouts/SiteHeader.astro";
import SiteFooter from "../components/layouts/SiteFooter.astro";
import HeaderScrollScript from "../components/layouts/HeaderScrollScript.astro";
import type { Locale, PageKey } from "../i18n";
import { localeMeta } from "../i18n";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: string;
  robots?: string;
  headerOffset?: boolean;
  locale?: Locale;
  pageKey?: PageKey;
  alternates?: Record<string, string>;
}

const pageTitle = Astro.props.title ?? "Iturribero Abereak";
const pageDescription =
  Astro.props.description ??
  "Explotación agroganadera familiar en Durana, Álava. Vacuno de carne y cultivos cerealistas.";

const pageImage = Astro.props.image ?? "/hero-colza.jpg";
const canonicalUrl = Astro.props.canonical ?? Astro.url.href;
const pageType = Astro.props.type ?? "website";
const pageRobots =
  Astro.props.robots ??
  "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";
const headerOffset = Astro.props.headerOffset ?? false;
const locale = Astro.props.locale ?? "es";
const pageKey = Astro.props.pageKey;
const alternates = Astro.props.alternates ?? {};
const langMeta = localeMeta[locale];
---

<html lang={langMeta.lang}>
  <head>
    <SeoHead
      title={pageTitle}
      description={pageDescription}
      image={pageImage}
      canonical={canonicalUrl}
      type={pageType}
      robots={pageRobots}
      lang={langMeta.lang}
      ogLocale={langMeta.ogLocale}
      alternates={alternates}
    />
  </head>

  <body class="bg-gray-50 text-gray-900 antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-NHDHMVVK"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>
    <!-- End Google Tag Manager -->

    <SiteHeader locale={locale} pageKey={pageKey} />

    <main class={`min-h-screen ${headerOffset ? "pt-20 md:pt-24" : ""}`}>
      <slot />
    </main>

    <SiteFooter locale={locale} pageKey={pageKey} />
    <HeaderScrollScript />
  </body>
</html>
