---
import "../styles/global.css";
import SeoHead from "../components/layouts/SeoHead.astro";
import SiteHeader from "../components/layouts/SiteHeader.astro";
import SiteFooter from "../components/layouts/SiteFooter.astro";
import HeaderScrollScript from "../components/layouts/HeaderScrollScript.astro";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
}

const pageTitle = Astro.props.title ?? "Iturribero Abereak";
const pageDescription =
  Astro.props.description ??
  "Explotación agroganadera familiar en Durana (Arrazua-Ubarrundia, Álava). Vacas de carne y cultivos cerealistas.";

const pageImage = Astro.props.image ?? "/hero-colza.jpg";
const canonicalUrl = Astro.props.canonical ?? Astro.url.href;
---

<html lang="es">
  <head>
    <SeoHead
      title={pageTitle}
      description={pageDescription}
      image={pageImage}
      canonical={canonicalUrl}
    />
  </head>

  <body class="bg-gray-50 text-gray-900 antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-NHDHMVVK"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>
    <!-- End Google Tag Manager -->

    <SiteHeader />

    <main class="pt-[72px]">
      <slot />
    </main>

    <SiteFooter />
    <HeaderScrollScript />
  </body>
</html>