---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
---

<Layout
  title="Servicios agroganaderos en Durana, Álava | Iturribero Abereak"
  description="Ganadería de vacuno de carne, agricultura y contacto con Iturribero Abereak en Durana, Álava."
  image="/hero-colza.jpg"
  canonical="https://iturriberoabereak.com/servicios"
>
  <section class="section-shell bg-white">
    <div class="section-inner">
      <div class="max-w-4xl">
        <p class="eyebrow mb-4">
          Servicios
        </p>

        <h1 class="section-title">
          Ganadería, agricultura
          <span class="block">y trato cercano.</span>
        </h1>

        <p class="section-copy mt-5 max-w-2xl">
          Iturribero Abereak reúne el trabajo con vacuno de carne, el cultivo de
          cereal y forraje y una relación directa con quien quiere conocernos,
          consultar algo concreto o acercarse a la explotación.
        </p>
      </div>

      <div class="mt-12 grid gap-5 md:grid-cols-3">
        <a
          href="/ganaderia"
          class="rounded-[1.75rem] border border-stone-200 bg-stone-50 p-6 no-underline transition hover:-translate-y-1 hover:shadow-[0_20px_50px_-42px_rgba(28,25,23,0.22)]"
        >
          <p class="text-xs uppercase tracking-[0.28em] text-stone-500">
            Ganadería
          </p>
          <h2 class="mt-4 text-2xl font-semibold text-stone-950">
            Vacuno de carne
          </h2>
          <p class="mt-4 text-sm leading-6 text-stone-600 md:text-base">
            Manejo diario, bienestar animal y una explotación familiar que trabaja
            con continuidad, observación y responsabilidad.
          </p>
        </a>

        <a
          href="/agricultura"
          class="rounded-[1.75rem] border border-stone-200 bg-stone-50 p-6 no-underline transition hover:-translate-y-1 hover:shadow-[0_20px_50px_-42px_rgba(28,25,23,0.22)]"
        >
          <p class="text-xs uppercase tracking-[0.28em] text-stone-500">
            Agricultura
          </p>
          <h2 class="mt-4 text-2xl font-semibold text-stone-950">
            Cultivo de campaña
          </h2>
          <p class="mt-4 text-sm leading-6 text-stone-600 md:text-base">
            Trigo, cebada, avena, maíz, colza, veza y hierba trabajados con
            calendario, cuidado del suelo y conexión real con la ganadería.
          </p>
        </a>

        <a
          href="/contacto"
          class="rounded-[1.75rem] border border-stone-900 bg-stone-950 p-6 text-white no-underline transition hover:-translate-y-1 hover:shadow-[0_20px_50px_-42px_rgba(28,25,23,0.32)]"
        >
          <p class="text-xs uppercase tracking-[0.28em] text-amber-200/90">
            Contacto
          </p>
          <h2 class="mt-4 text-2xl font-semibold">
            Consultas y visitas
          </h2>
          <p class="mt-4 text-sm leading-6 text-white/76 md:text-base">
            Un canal directo para resolver dudas, plantear una colaboración o
            preparar una visita con contexto y calma.
          </p>
        </a>
      </div>
    </div>
  </section>
</Layout>
