---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Iturribero Abereak | Ganadería y agricultura en Durana, Álava"
  description="Explotación agroganadera familiar en Durana (Arrazua-Ubarrundia, Álava). Vacas de carne y cultivos cerealistas y forrajeros."
  image="/hero-colza.jpg"
>

  <!-- HERO FULL SCREEN -->
  <section class="relative h-screen w-full overflow-hidden -mt-[72px] pt-[72px]">
    <img
      src="/hero-colza.jpg"
      alt="Campos de colza"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/55 via-black/35 to-black/15"></div>

    <div class="relative z-10 h-full flex items-center md:items-center">
      <div class="max-w-7xl mx-auto px-8 w-full">
       <div class="max-w-xl text-white pt-10 md:pt-0">
          <p class="uppercase tracking-[0.25em] text-yellow-200 text-sm mb-5">
            Actividad agroganadera
          </p>

          <h1 class="text-5xl md:text-6xl font-semibold leading-tight mb-6">
            Iturribero Abereak
          </h1>

          <p class="text-lg text-white/90 leading-relaxed mb-10">
            Ganadería y agricultura con compromiso con el bienestar animal,
            el cuidado del entorno y la calidad.
          </p>

          <a
            href="/quienes-somos"
            class="inline-flex items-center gap-2 px-7 py-3 rounded-full bg-white/90 text-gray-900 text-sm font-semibold tracking-wide hover:bg-white transition shadow-sm border border-white/40 backdrop-blur"
          >
            Conocer el proyecto <span class="opacity-70">→</span>
          </a>

          <div class="mt-10 flex items-center gap-3 text-white/80 text-sm">
            <span class="inline-block w-10 h-[1px] bg-white/60"></span>
            Desliza para ver más
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-6 left-0 right-0 flex justify-center">
      <div class="text-white/80 animate-bounce">⌄</div>
    </div>
  </section>

  <!-- FRASE / MANIFIESTO (opcional pero queda muy bien) -->
  <section class="w-full bg-slate-50 py-24 border-t border-gray-200">
  <div class="max-w-6xl mx-auto px-8">
    <p class="text-xs uppercase tracking-[0.35em] text-gray-400 mb-5">
      Nuestro enfoque
    </p>
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold leading-tight text-gray-900">
      Trabajamos el campo con respeto por los animales,
      cuidado por la tierra y compromiso con cada campaña.
    </h2>
  </div>
</section>

  <!-- BLOQUES PRINCIPALES FULL WIDTH -->
  <section class="w-full">

    <!-- GANADERÍA -->
    <a href="/ganaderia" class="group block">
      <div class="relative w-full h-[360px] md:h-[420px] overflow-hidden">
        <img
          src="/vaca_primer-plano.jpg"
          alt="Ganadería"
          class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
        />

        <div class="absolute inset-0 bg-gradient-to-r from-black/65 via-black/25 to-transparent"></div>

        <!-- corte diagonal -->
        <div class="absolute inset-0">
          <div class="absolute top-0 left-0 h-full w-[60%] bg-black/25 [clip-path:polygon(0_0,70%_0,50%_100%,0_100%)]"></div>
        </div>

        <div class="relative z-10 h-full flex items-center px-10 md:px-20 lg:px-28 xl:px-36">
          <div class="max-w-md text-white">
            <p class="uppercase tracking-[0.25em] text-yellow-200 text-xs mb-3">
              Ganadería
            </p>

            <h2 class="text-3xl md:text-4xl font-semibold leading-tight">
              Bienestar y cuidado del ganado
            </h2>

            <p class="mt-3 text-white/90 leading-relaxed">
              Seguimiento del ganado y manejo responsable orientado a la calidad.
            </p>

            <span class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-white">
  Ver ganadería <span class="opacity-70">→</span>
</span>
          </div>
        </div>
      </div>
    </a>

    <!-- AGRICULTURA -->
    <a href="/agricultura" class="group block">
      <div class="relative w-full h-[360px] md:h-[420px] overflow-hidden">
        <img
          src="/cebada.jpg"
          alt="Agricultura"
          class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
        />

        <div class="absolute inset-0 bg-gradient-to-l from-black/65 via-black/25 to-transparent"></div>

        <!-- corte diagonal invertido -->
        <div class="absolute inset-0">
          <div class="absolute top-0 right-0 h-full w-[60%] bg-black/25 [clip-path:polygon(30%_0,100%_0,100%_100%,50%_100%)]"></div>
        </div>

        <div class="relative z-10 h-full flex items-center justify-end px-10 md:px-20 lg:px-28 xl:px-36">
          <div class="max-w-md text-white text-left md:text-right">
            <p class="uppercase tracking-[0.25em] text-yellow-200 text-xs mb-3">
              Agricultura
            </p>

            <h2 class="text-3xl md:text-4xl font-semibold leading-tight">
              Campo, cultivo y trabajo de temporada
            </h2>

            <p class="mt-3 text-white/90 leading-relaxed">
              Cultivo responsable y cuidado del suelo.
            </p>

            <span class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-white">
  Ver agricultura <span class="opacity-70">→</span>
</span>
            </span>
          </div>
        </div>
      </div>
    </a>

  </section>

<!-- NUESTRA MANERA DE HACER (más visual, sin tarjetas clásicas) -->
<section class="w-full bg-white border-t border-gray-200 py-4">
  <div class="max-w-6xl mx-auto px-8 py-20">

    <p class="text-xs uppercase tracking-[0.35em] text-gray-400 mb-5">
      Nuestra manera de hacer
    </p>

    <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold leading-tight text-gray-900">
      Menos ruido. Más campo.
      <br class="hidden md:block" />
      Trabajo constante, decisiones responsables.
    </h2>

    <!-- Línea fina para dar “estructura editorial” -->
    <div class="mt-10 h-px w-full bg-gray-200"></div>

    <!-- Principios -->
    <div class="mt-10 grid grid-cols-1 md:grid-cols-3 gap-10">

      <div class="relative pl-6">
        <div class="absolute left-0 top-1 w-1 h-10 rounded-full bg-gray-900"></div>
        <p class="text-sm font-semibold text-gray-900">Bienestar animal</p>
        <p class="text-gray-600 mt-2 leading-relaxed">
          Manejo responsable y seguimiento del ganado.
        </p>
        <div class="mt-4 text-xs uppercase tracking-[0.25em] text-gray-400">
          Cuidado • Rutina • Calidad
        </div>
      </div>

      <div class="relative pl-6">
        <div class="absolute left-0 top-1 w-1 h-10 rounded-full bg-gray-900"></div>
        <p class="text-sm font-semibold text-gray-900">Cuidado del suelo</p>
        <p class="text-gray-600 mt-2 leading-relaxed">
          Prácticas sostenibles y respeto por la tierra.
        </p>
        <div class="mt-4 text-xs uppercase tracking-[0.25em] text-gray-400">
          Suelo • Sostenibilidad • Campañas
        </div>
      </div>

      <div class="relative pl-6">
        <div class="absolute left-0 top-1 w-1 h-10 rounded-full bg-gray-900"></div>
        <p class="text-sm font-semibold text-gray-900">Calidad y transparencia</p>
        <p class="text-gray-600 mt-2 leading-relaxed">
          Claridad en los procesos y mejora continua.
        </p>
        <div class="mt-4 text-xs uppercase tracking-[0.25em] text-gray-400">
          Claridad • Control • Mejora
        </div>
      </div>

    </div>

  </div>
</section>


</Layout>