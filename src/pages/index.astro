---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import Herohome from "../components/sections/home/Herohome.astro";
import ManifestoSection from "../components/sections/home/ManifestoSection.astro";
import HomeAreasSection from "../components/sections/home/HomeAreasSection.astro";
import HowWeWorkSection from "../components/sections/home/HowWeWorkSection.astro";
import { getAlternateEntries } from "../i18n";
---

<Layout
  title="Ganadería y agricultura en Durana, Álava | Iturribero Abereak"
  description="Explotación agroganadera familiar en Durana, Álava. Vacuno de carne, cultivos cerealistas y forrajeros trabajados con cuidado, continuidad y arraigo al territorio."
  image="/hero-colza.jpg"
  canonical="https://iturriberoabereak.com/"
  locale="es"
  pageKey="home"
  alternates={getAlternateEntries("home")}
>
  <Herohome locale="es" />
  <ManifestoSection locale="es" />
  <HomeAreasSection locale="es" />
  <HowWeWorkSection locale="es" />
</Layout>
