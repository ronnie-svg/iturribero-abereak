---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";

import AgriculturaHero from "../components/sections/agricultura/AgriculturaHero.astro";
import AgriculturaIntro from "../components/sections/agricultura/AgriculturaIntro.astro";
import AgriculturaVisualCta from "../components/sections/agricultura/AgriculturaVisualCta.astro";
import AgriculturaMediaGallery from "../components/sections/agricultura/AgriculturaMediaGallery.astro";
import { getAlternateEntries } from "../i18n";
---

<Layout
  title="Agricultura en Durana, Álava | Iturribero Abereak"
  description="Cultivos cerealistas y forrajeros en Durana, Álava. Trigo, cebada, avena, maíz, colza, veza y hierba trabajados con planificación, cuidado del suelo y conexión con la ganadería."
  image="/hero-colza.jpg"
  canonical="https://iturriberoabereak.com/agricultura"
  locale="es"
  pageKey="agriculture"
  alternates={getAlternateEntries("agriculture")}
>
  <AgriculturaHero locale="es" />
  <AgriculturaIntro locale="es" />
  <AgriculturaVisualCta locale="es" />
  <AgriculturaMediaGallery locale="es" />
</Layout>
