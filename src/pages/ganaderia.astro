---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";

import GanaderiaHero from "../components/sections/ganaderia/GanaderiaHero.astro";
import GanaderiaIntro from "../components/sections/ganaderia/GanaderiaIntro.astro";
import GanaderiaVisualCta from "../components/sections/ganaderia/GanaderiaVisualCta.astro";
import GanaderiaGallery from "../components/sections/ganaderia/GanaderiaGallery.astro";
import { getAlternateEntries } from "../i18n";
---

<Layout
  title="Ganadería de vacuno de carne en Durana, Álava | Iturribero Abereak"
  description="Ganadería de vacuno de carne en Durana, Álava. Bienestar animal, manejo responsable, seguimiento diario y una explotación familiar conectada con el ritmo del campo."
  image="/vaca_primer-plano.jpg"
  canonical="https://iturriberoabereak.com/ganaderia"
  locale="es"
  pageKey="livestock"
  alternates={getAlternateEntries("livestock")}
>
  <GanaderiaHero locale="es" />
  <GanaderiaIntro locale="es" />
  <GanaderiaVisualCta locale="es" />
  <GanaderiaGallery locale="es" />
</Layout>
