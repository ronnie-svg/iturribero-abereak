---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import ContactForm from "../../components/contacts/ContactForm.astro";
import { Image } from "astro:assets";
import tierraImg from "../../assets/agricultura/tierra.jpg";
import { getAlternateEntries } from "../../i18n";
---

<Layout
  title="Kontaktua Duranan, Araban | Iturribero Abereak"
  description="Jarri harremanetan Iturribero Abereakekin Duranan, Araban. Kontsultak, bisitak edo elkarlanerako aukerak familia ustiapen agroabeltzain batekin."
  image="/tierra.jpg"
  headerOffset={true}
  canonical="https://iturriberoabereak.com/eu/kontaktua"
  locale="eu"
  pageKey="contact"
  alternates={getAlternateEntries("contact")}
>
  <section class="relative isolate overflow-hidden border-b border-stone-200 bg-stone-950 text-white">
    <div class="absolute inset-0">
      <Image
        src={tierraImg}
        alt="Iturribero Abereakekin harremanetan jartzeko irudia"
        class="h-full w-full object-cover object-center"
        sizes="100vw"
        loading="eager"
        priority
      />
      <div class="absolute inset-0 bg-[linear-gradient(120deg,_rgba(12,10,9,0.72),_rgba(12,10,9,0.32)_42%,_rgba(12,10,9,0.58))]"></div>
      <div class="absolute inset-0 bg-[linear-gradient(to_top,_rgba(12,10,9,0.64),_rgba(12,10,9,0.08)_40%,_rgba(12,10,9,0.26))]"></div>
    </div>

    <div class="relative mx-auto flex min-h-[58vh] max-w-7xl items-end px-6 py-14 md:min-h-[62vh] md:px-8 md:py-16">
      <div class="max-w-2xl">
        <h1 class="text-5xl font-semibold leading-[0.96] tracking-[-0.045em] text-white sm:text-6xl lg:text-7xl">
          Hitz egin dezagun.
        </h1>

        <p class="mt-6 max-w-xl text-base leading-7 text-white/78 md:text-lg">
          Kontsulta bat egin nahi baduzu, bisita bat proposatu edo arrazoiren
          batengatik idatzi nahi badiguzu, hemen duzu bide zuzen eta erraza.
        </p>
      </div>
    </div>
  </section>

  <section class="section-shell bg-white">
    <div class="section-inner pb-10 md:pb-14">
      <div class="grid gap-10 lg:grid-cols-12 lg:items-start">
        <div class="lg:col-span-5">
          <p class="eyebrow mb-4">
            Iturribero Abereak
          </p>

          <h2 class="section-title text-4xl md:text-5xl">
            Durana, Araba.
          </h2>

          <p class="section-copy mt-5 max-w-xl">
            Lurrari, aziendari eta eguneroko lanari lotutako familia ustiapen
            agroabeltzaina. Informazioa behar baduzu, bisita egin nahi baduzu
            edo gurekin hitz egin nahi baduzu, hemendik idatz diezagukezu.
          </p>

          <div class="mt-10 space-y-4">
            <div class="rounded-[1.75rem] border border-stone-200 bg-stone-50 p-5">
              <p class="text-xs uppercase tracking-[0.25em] text-stone-500">Emaila</p>
              <p class="mt-2 font-semibold text-stone-950">info@iturriberoabereak.com</p>
            </div>

            <div class="rounded-[1.75rem] border border-stone-200 bg-stone-50 p-5">
              <p class="text-xs uppercase tracking-[0.25em] text-stone-500">Kokapena</p>
              <p class="mt-2 font-semibold text-stone-950">Durana - Arrazua-Ubarrundia - Araba</p>
              <p class="mt-2 text-sm text-stone-600">
                Etortzekotan bazara, idatzi lehenago eta sarbidea zehaztasunez azalduko dizugu.
              </p>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap gap-3">
            <a
              href="mailto:info@iturriberoabereak.com"
              class="inline-flex items-center justify-center rounded-full bg-stone-950 px-6 py-3 text-sm font-semibold text-white transition hover:bg-stone-800"
            >
              Bidali emaila
            </a>

            <a
              href="https://www.google.com/maps/search/?api=1&query=Durana%2C%20Arrazua-Ubarrundia%2C%20Alava"
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center justify-center rounded-full border border-stone-300 px-6 py-3 text-sm font-semibold text-stone-900 transition hover:bg-stone-50"
            >
              Ireki mapa
            </a>
          </div>
        </div>

        <div class="lg:col-span-7">
          <div class="overflow-hidden rounded-[2rem] border border-stone-200 bg-white shadow-[0_24px_70px_-48px_rgba(28,25,23,0.28)]">
            <div class="p-8 md:p-10">
              <p class="eyebrow mb-3">
                Formularioa
              </p>

              <h3 class="text-2xl font-semibold text-stone-950 md:text-3xl">
                Idatzi iezaguzu
              </h3>

              <p class="mt-3 max-w-xl text-sm leading-6 text-stone-600 md:text-base">
                Kontaiguzu zer behar duzun eta ahalik eta argien erantzungo dizugu.
              </p>

              <div class="mt-8">
                <ContactForm locale="eu" />
              </div>
            </div>

            <div class="border-t border-stone-200 bg-stone-50 px-8 py-6 md:px-10">
              <p class="text-sm text-stone-600">
                Nahiago baduzu, zuzenean ere idatz diezagukezu posta elektronikoz.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell bg-stone-50">
    <div class="section-inner pt-10 md:pt-14">
      <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
        <div class="max-w-2xl">
          <p class="eyebrow mb-3">
            Kokapena
          </p>

          <h2 class="section-title text-3xl md:text-4xl">
            Durana - Arrazua-Ubarrundia - Araba
          </h2>

          <p class="section-copy mt-4">
            Duranan gaude. Hurbiltzekotan bazara, abisatu aurretik eta sarrera
            modu errazenean azalduko dizugu.
          </p>
        </div>
      </div>

      <div class="mt-10 overflow-hidden rounded-[2rem] border border-stone-200 bg-white shadow-[0_24px_70px_-48px_rgba(28,25,23,0.24)]">
        <iframe
          title="Mapa Durana"
          class="h-95 w-full md:h-115"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps?q=Durana%2C%20Arrazua-Ubarrundia%2C%20Alava&output=embed"
        ></iframe>
      </div>
    </div>
  </section>
</Layout>
