---
import Layout from "../layouts/Layout.astro";
import '../styles/global.css';
import TimelineGeneraciones from "../components/TimelineGeneraciones.astro";
---
---

<Layout
  title="Quiénes somos | Iturribero Abereak"
  description="Conoce Iturribero Abereak, una explotación agroganadera familiar en Durana (Álava), actualmente en su tercera generación."
  image="/txabola.jpg"
>

  <!-- HERO (sin -mt para que NO se meta bajo el header) -->
  <section class="relative h-[70vh] md:h-[75vh] w-full overflow-hidden">
    <img
      src="/txabola.jpg"
      alt="Iturribero Abereak"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/55 via-black/35 to-black/15"></div>

    <div class="relative z-10 h-full flex items-end">
      <div class="max-w-7xl mx-auto px-8 pb-14 w-full">
        <div class="max-w-2xl text-white">
          <p class="uppercase tracking-[0.25em] text-yellow-200 text-xs md:text-sm mb-4">
            Quiénes somos
          </p>

          <h1 class="text-4xl md:text-6xl font-semibold leading-tight">
            Campo y vacas,
            <br class="hidden md:block" />
            en familia.
          </h1>

          <p class="mt-5 text-white/90 text-lg leading-relaxed">
            Explotación agroganadera familiar en Durana (Arrazua-Ubarrundia, Álava),
            actualmente en su tercera generación.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOQUE EDITORIAL (blanco) -->
  <section class="w-full bg-white border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-8 py-20">
      <p class="text-xs uppercase tracking-[0.35em] text-gray-400 mb-5">
        Nuestra manera de hacer
      </p>

      <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold leading-tight text-gray-900">
        Menos ruido. Más campo.
        <br class="hidden md:block" />
        Trabajo constante, decisiones responsables.
      </h2>

      <div class="mt-10 h-px w-full bg-gray-200"></div>

      <div class="mt-10 grid grid-cols-1 md:grid-cols-3 gap-10">
        <div class="relative pl-6">
          <div class="absolute left-0 top-1 w-1 h-10 rounded-full bg-gray-900"></div>
          <p class="text-sm font-semibold text-gray-900">Tercera generación</p>
          <p class="text-gray-600 mt-2 leading-relaxed">
            Oficio heredado, conocimiento práctico y un proyecto de tamaño humano.
          </p>
        </div>

        <div class="relative pl-6">
          <div class="absolute left-0 top-1 w-1 h-10 rounded-full bg-gray-900"></div>
          <p class="text-sm font-semibold text-gray-900">Vacas de carne</p>
          <p class="text-gray-600 mt-2 leading-relaxed">
            Bienestar animal, seguimiento y manejo responsable en el día a día.
          </p>
        </div>

        <div class="relative pl-6">
          <div class="absolute left-0 top-1 w-1 h-10 rounded-full bg-gray-900"></div>
          <p class="text-sm font-semibold text-gray-900">Ciclo campo–ganado</p>
          <p class="text-gray-600 mt-2 leading-relaxed">
            Cultivamos parte de la alimentación: trigo, cebada, avena, maíz, colza, veza y hierba.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOQUE EDITORIAL (gris sutil) -->

  <section class="w-full bg-slate-100 border-t border-gray-200">
  <div class="max-w-7xl mx-auto px-8 py-20">

    <p class="text-xs uppercase tracking-[0.35em] text-gray-400 mb-4">
      Nuestra historia
    </p>

    <p class="text-xl leading-relaxed text-gray-700">
      La explotación ha pasado de generación en generación.
      Hoy seguimos trabajando en Durana combinando ganadería
      de vacas de carne y cultivo de cereal, manteniendo
      una forma de trabajar cercana y responsable.
    </p>

  </div>
</section>

<!-- LÍNEA TEMPORAL -->
<TimelineGeneraciones />

  <!-- DOS BLOQUES GRANDES (gris sutil) -->
  <section class="w-full bg-white border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-8 py-20 grid lg:grid-cols-2 gap-10">

      <!-- Ganadería -->
      <div class="rounded-[28px] border border-gray-200 overflow-hidden bg-white">
        <div class="relative h-[300px]">
          <img
            src="/vaca_primer-plano.jpg"
            alt="Vacas de carne"
            class="absolute inset-0 w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-r from-black/55 via-black/25 to-transparent"></div>

          <div class="absolute bottom-6 left-6 right-6 text-white">
            <p class="text-xs uppercase tracking-[0.35em] text-yellow-200">Ganadería</p>
            <h3 class="mt-1 text-2xl font-semibold">Vacas de carne</h3>
          </div>
        </div>

        <div class="p-12">
          <p class="text-gray-600 leading-relaxed">
            Manejo responsable, bienestar animal y seguimiento. Al ser una explotación pequeña,
            podemos estar encima del día a día y cuidar los detalles.
          </p>

          <div class="mt-6 flex flex-wrap gap-2">
            <span class="text-xs px-3 py-1 rounded-full bg-gray-50 border border-gray-200 text-gray-700">Bienestar</span>
            <span class="text-xs px-3 py-1 rounded-full bg-gray-50 border border-gray-200 text-gray-700">Seguimiento</span>
            <span class="text-xs px-3 py-1 rounded-full bg-gray-50 border border-gray-200 text-gray-700">Manejo responsable</span>
          </div>

          <a href="/ganaderia" class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-gray-900 hover:text-gray-700 transition">
            Ver ganadería <span class="opacity-70">→</span>
          </a>
        </div>
      </div>

      <!-- Agricultura -->
      <div class="rounded-[28px] border border-gray-200 overflow-hidden bg-white">
        <div class="relative h-[300px]">
          <img
            src="/cebada.jpg"
            alt="Cultivos"
            class="absolute inset-0 w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-r from-black/45 via-black/15 to-transparent"></div>

          <div class="absolute bottom-6 left-6 right-6 text-white">
            <p class="text-xs uppercase tracking-[0.35em] text-yellow-200">Agricultura</p>
            <h3 class="mt-1 text-2xl font-semibold">Cultivos para el ganado</h3>
          </div>
        </div>

        <div class="p-12">
          <p class="text-gray-600 leading-relaxed">
            Cultivamos cereal (trigo, cebada, avena y maíz) para alimentar a nuestras vacas,
            además de colza, veza y hierba. Campo y ganado forman parte del mismo ciclo.
          </p>

          <div class="mt-6 flex flex-wrap gap-2">
            <span class="text-xs px-3 py-1 rounded-full bg-gray-50 border border-gray-200 text-gray-700">Trigo</span>
            <span class="text-xs px-3 py-1 rounded-full bg-gray-50 border border-gray-200 text-gray-700">Cebada</span>
            <span class="text-xs px-3 py-1 rounded-full bg-gray-50 border border-gray-200 text-gray-700">Avena</span>
            <span class="text-xs px-3 py-1 rounded-full bg-gray-50 border border-gray-200 text-gray-700">Maíz</span>
            <span class="text-xs px-3 py-1 rounded-full bg-gray-50 border border-gray-200 text-gray-700">Colza</span>
            <span class="text-xs px-3 py-1 rounded-full bg-gray-50 border border-gray-200 text-gray-700">Veza</span>
            <span class="text-xs px-3 py-1 rounded-full bg-gray-50 border border-gray-200 text-gray-700">Hierba</span>
          </div>

          <a href="/agricultura" class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-gray-900 hover:text-gray-700 transition">
            Ver agricultura <span class="opacity-70">→</span>
          </a>
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- GALERÍA (blanco) -->
  <section class="w-full bg-white border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-8 py-20">
      <div class="grid md:grid-cols-3 gap-6">
        <img src="/tierra.jpg" alt="Tierra" class="rounded-3xl h-64 w-full object-cover border border-gray-200" />
        <img src="/deutz.jpg" alt="Trabajo de campo" class="rounded-3xl h-64 w-full object-cover border border-gray-200" />
        <img src="/girasol.jpg" alt="Girasol" class="rounded-3xl h-64 w-full object-cover border border-gray-200" />
      </div>
    </div>
  </section>

  
</Layout>