---
export interface Props {
  title: string;
  description: string;
  image: string;
  canonical: string;
  type?: string;
  robots?: string;
  lang?: string;
  ogLocale?: string;
  alternates?: Record<string, string>;
}

const {
  title,
  description,
  image,
  canonical,
  type = "website",
  robots = "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1",
  lang = "es",
  ogLocale = "es_ES",
  alternates = {},
} = Astro.props;
const imageUrl = image.startsWith("http")
  ? image
  : new URL(image, Astro.site ?? canonical).toString();

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${canonical}#website`,
      url: canonical,
      name: "Iturribero Abereak",
      description,
      inLanguage: lang,
    },
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      url: canonical,
      name: title,
      isPartOf: {
        "@id": `${canonical}#website`,
      },
      about: {
        "@id": `${canonical}#organization`,
      },
      description,
      inLanguage: lang,
    },
    {
      "@type": "LocalBusiness",
      "@id": `${canonical}#organization`,
      "@context": "https://schema.org",
      "name": "Iturribero Abereak",
      "image": imageUrl,
      "url": canonical,
      "description": "Explotación agroganadera familiar en Durana, Álava. Ganadería de vacuno de carne y cultivos cerealistas y forrajeros trabajados con cuidado y arraigo al territorio.",
      "additionalType": ["FarmBusiness", "AgriculturalBusiness"],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Durana",
        "addressLocality": "Durana",
        "addressRegion": "Álava",
        "addressCountry": "ES",
      },
      "areaServed": [
        {
          "@type": "AdministrativeArea",
          "name": "Álava",
        },
        {
          "@type": "AdministrativeArea",
          "name": "Durana",
        }
      ],
      "knowsAbout": [
        "Ganadería de carne",
        "Cultivos cerealistas",
        "Cultivos forrajeros",
        "Agricultura sostenible",
        "Explotación agroganadera"
      ],
      "sameAs": [canonical],
    },
  ],
};

const gtmHeadScript = `
(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-NHDHMVVK');
`;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content="Iturribero Abereak" />
<meta name="robots" content={robots} />
<meta name="theme-color" content="#1c1917" />
<meta name="format-detection" content="telephone=no" />

<link rel="canonical" href={canonical} />
<link rel="icon" href="/Iturriberoabereaklogo.svg" type="image/svg+xml" />
{Object.entries(alternates).map(([hrefLang, href]) => (
  <link rel="alternate" hreflang={hrefLang} href={href} />
))}
<link rel="alternate" hreflang="x-default" href={alternates.es ?? canonical} />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:alt" content={title} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:site_name" content="Iturribero Abereak" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
<meta name="twitter:image:alt" content={title} />

<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify(schema)}
/>

<!-- Google Tag Manager -->
<script is:inline set:html={gtmHeadScript}></script>
<!-- End Google Tag Manager -->
