<script is:inline>
  const header = document.getElementById("site-header");
  const brandText = document.getElementById("brand-text");

  const navQs = document.getElementById("nav-qs");
  const navGan = document.getElementById("nav-gan");
  const navAgr = document.getElementById("nav-agr");
  const navContact = document.getElementById("nav-contact");
  const localeCurrent = document.getElementById("locale-current");
  const localeTarget = document.getElementById("locale-target");
  const localeDivider = document.getElementById("locale-divider");

  const mobileMenuButton = document.getElementById("mobile-menu-button");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileBackdrop = document.getElementById("mobile-menu-backdrop");
  const iconMenu = document.getElementById("icon-menu");
  const iconClose = document.getElementById("icon-close");

  const isHome =
    window.location.pathname === "/" ||
    window.location.pathname === "/index.html" ||
    window.location.pathname === "/eu/" ||
    window.location.pathname === "/eu/index.html";

  const THRESHOLD = 12;
  let mobileOpen = false;

  function isActiveLink(link) {
    return link?.dataset.active === "true";
  }

  function lockBodyScroll(locked) {
    document.body.classList.toggle("overflow-hidden", locked);
  }

  function openMobileMenu() {
    if (!mobileMenu || !mobileMenuButton || !iconMenu || !iconClose || !mobileBackdrop) return;

    mobileOpen = true;
    mobileMenu.classList.remove("invisible", "pointer-events-none", "opacity-0");
    mobileMenu.classList.add("visible", "pointer-events-auto", "opacity-100");
    mobileBackdrop.classList.remove("pointer-events-none", "opacity-0");
    mobileBackdrop.classList.add("pointer-events-auto", "opacity-100", "bg-black/30");
    iconMenu.classList.add("hidden");
    iconClose.classList.remove("hidden");
    mobileMenuButton.setAttribute("aria-expanded", "true");
    mobileMenuButton.setAttribute(
      "aria-label",
      mobileMenuButton.dataset.labelClose ?? "Cerrar menu"
    );
    lockBodyScroll(true);
  }

  function closeMobileMenu() {
    if (!mobileMenu || !mobileMenuButton || !iconMenu || !iconClose || !mobileBackdrop) return;

    mobileOpen = false;
    mobileMenu.classList.add("invisible", "pointer-events-none", "opacity-0");
    mobileMenu.classList.remove("visible", "pointer-events-auto", "opacity-100");
    mobileBackdrop.classList.add("pointer-events-none", "opacity-0");
    mobileBackdrop.classList.remove("pointer-events-auto", "opacity-100", "bg-black/30");
    iconMenu.classList.remove("hidden");
    iconClose.classList.add("hidden");
    mobileMenuButton.setAttribute("aria-expanded", "false");
    mobileMenuButton.setAttribute(
      "aria-label",
      mobileMenuButton.dataset.labelOpen ?? "Abrir menu"
    );
    lockBodyScroll(false);
  }

  function setTransparent() {
    if (!header || !brandText) return;

    header.className =
      "fixed left-0 right-0 top-0 z-50 bg-gradient-to-b from-black/35 to-transparent transition-all duration-300";

    brandText.className = "text-lg font-semibold tracking-tight text-white";

    if (navQs) {
      navQs.className = isActiveLink(navQs)
        ? "text-white/92"
        : "text-white transition hover:text-white/78";
    }
    if (navGan) {
      navGan.className = isActiveLink(navGan)
        ? "text-white/92"
        : "text-white transition hover:text-white/78";
    }
    if (navAgr) {
      navAgr.className = isActiveLink(navAgr)
        ? "text-white/92"
        : "text-white transition hover:text-white/78";
    }

    if (navContact) {
      navContact.className = isActiveLink(navContact)
        ? "inline-flex items-center justify-center rounded-full bg-amber-300 px-5 py-2 font-semibold text-stone-950 transition"
        : "inline-flex items-center justify-center rounded-full border border-white/25 bg-white/15 px-5 py-2 font-semibold text-white transition hover:bg-white/25";
    }

    if (mobileMenuButton) {
      mobileMenuButton.className =
        "inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/25 bg-white/10 text-white transition hover:bg-white/20";
    }

    if (localeCurrent) {
      localeCurrent.className = "text-white/68";
    }
    if (localeDivider) {
      localeDivider.className = "text-white/26";
    }
    if (localeTarget) {
      localeTarget.className = "text-white/68 transition hover:text-white/92";
    }
  }

  function setSolid() {
    if (!header || !brandText) return;

    header.className =
      "fixed left-0 right-0 top-0 z-50 bg-white/90 shadow-sm backdrop-blur transition-all duration-300";

    brandText.className = "text-lg font-semibold tracking-tight text-gray-900";

    if (navQs) {
      navQs.className = isActiveLink(navQs)
        ? "text-stone-950"
        : "text-gray-700 transition hover:text-gray-950";
    }
    if (navGan) {
      navGan.className = isActiveLink(navGan)
        ? "text-stone-950"
        : "text-gray-700 transition hover:text-gray-950";
    }
    if (navAgr) {
      navAgr.className = isActiveLink(navAgr)
        ? "text-stone-950"
        : "text-gray-700 transition hover:text-gray-950";
    }

    if (navContact) {
      navContact.className = isActiveLink(navContact)
        ? "inline-flex items-center justify-center rounded-full bg-amber-300 px-5 py-2 font-semibold text-stone-950 transition"
        : "inline-flex items-center justify-center rounded-full bg-gray-900 px-5 py-2 font-semibold text-white transition hover:bg-gray-800";
    }

    if (mobileMenuButton) {
      mobileMenuButton.className =
        "inline-flex h-11 w-11 items-center justify-center rounded-full border border-gray-300 bg-white text-gray-900 transition hover:bg-gray-50";
    }

    if (localeCurrent) {
      localeCurrent.className = "text-stone-900/78";
    }
    if (localeDivider) {
      localeDivider.className = "text-stone-400";
    }
    if (localeTarget) {
      localeTarget.className = "text-stone-600 transition hover:text-stone-950";
    }
  }

  function applyModeFromScroll() {
    if (!isHome || mobileOpen) {
      setSolid();
      return;
    }

    const scrollTop = window.scrollY || window.pageYOffset || 0;
    if (scrollTop > THRESHOLD) setSolid();
    else setTransparent();
  }

  function handleScroll() {
    window.requestAnimationFrame(applyModeFromScroll);
  }

  function handleResize() {
    if (window.innerWidth >= 768 && mobileOpen) {
      closeMobileMenu();
    }
    applyModeFromScroll();
  }

  function handleKeydown(event) {
    if (event.key === "Escape" && mobileOpen) {
      closeMobileMenu();
    }
  }

  mobileMenuButton?.addEventListener("click", () => {
    if (mobileOpen) closeMobileMenu();
    else openMobileMenu();
    applyModeFromScroll();
  });

  mobileBackdrop?.addEventListener("click", closeMobileMenu);

  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMobileMenu);
  });

  document.addEventListener("keydown", handleKeydown);
  window.addEventListener("scroll", handleScroll, { passive: true });
  window.addEventListener("load", applyModeFromScroll);
  window.addEventListener("resize", handleResize);

  applyModeFromScroll();
</script>
