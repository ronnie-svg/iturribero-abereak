---
const pathname = Astro.url.pathname;

const isActive = (href: string) =>
  pathname === href || (href !== "/" && pathname.startsWith(`${href}/`));

const navLinkClass = (href: string) =>
  isActive(href)
    ? "text-white/92"
    : "text-white transition hover:text-white/78";

const mobileLinkClass = (href: string) =>
  isActive(href)
    ? "rounded-[1.25rem] border border-amber-300/60 bg-amber-50 px-4 py-4 text-base font-medium text-stone-950 no-underline transition"
    : "rounded-[1.25rem] border border-stone-200 bg-stone-50 px-4 py-4 text-base font-medium text-stone-900 no-underline transition hover:bg-stone-100 hover:text-stone-950";
---

<header
  id="site-header"
  class="fixed left-0 right-0 top-0 z-50 bg-linear-to-b from-black/35 to-transparent transition-all duration-300"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-6 py-4">
    <a href="/" class="flex items-center gap-3 rounded-full focus-visible:ring-offset-transparent">
      <img
        src="/Iturriberoabereaklogo.svg"
        alt="Iturribero Abereak"
        class="h-10 w-auto"
      />
      <span id="brand-text" class="text-lg font-semibold tracking-tight text-white">
        Iturribero Abereak
      </span>
    </a>

    <nav class="hidden items-center gap-6 text-sm md:flex">
      <a id="nav-qs" href="/quienes-somos" data-active={isActive("/quienes-somos")} class={`${navLinkClass("/quienes-somos")} rounded-full px-1 py-1 focus-visible:ring-offset-transparent`}>
        Nuestra historia
      </a>
      <a id="nav-gan" href="/ganaderia" data-active={isActive("/ganaderia")} class={`${navLinkClass("/ganaderia")} rounded-full px-1 py-1 focus-visible:ring-offset-transparent`}>
        Ganaderia
      </a>
      <a id="nav-agr" href="/agricultura" data-active={isActive("/agricultura")} class={`${navLinkClass("/agricultura")} rounded-full px-1 py-1 focus-visible:ring-offset-transparent`}>
        Agricultura
      </a>

      <a
        id="nav-contact"
        href="/contacto"
        data-active={isActive("/contacto")}
        class={`inline-flex items-center justify-center rounded-full px-5 py-2 font-semibold transition ${
          isActive("/contacto")
            ? "bg-amber-300 text-stone-950"
            : "border border-white/25 bg-white/15 text-white hover:bg-white/25 active:translate-y-[1px]"
        }`}
      >
        Contacto
      </a>
    </nav>

    <div class="flex items-center md:hidden">
      <button
        id="mobile-menu-button"
        type="button"
        aria-label="Abrir menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/25 bg-white/10 text-white transition duration-200 hover:bg-white/20 active:scale-[0.98]"
      >
        <svg
          id="icon-menu"
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>

        <svg
          id="icon-close"
          xmlns="http://www.w3.org/2000/svg"
          class="hidden h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu-backdrop"
    class="pointer-events-none fixed inset-0 z-40 bg-black/0 opacity-0 transition duration-300 md:hidden"
    aria-hidden="true"
  ></div>

  <div
    id="mobile-menu"
    class="pointer-events-none invisible absolute left-0 right-0 top-full z-50 border-t border-stone-200/80 bg-white/96 opacity-0 shadow-xl backdrop-blur transition duration-300 md:hidden"
  >
    <nav class="mx-auto flex max-w-7xl flex-col gap-3 px-6 py-5">
      <a href="/quienes-somos" class={mobileLinkClass("/quienes-somos")}>
        Nuestra historia
      </a>

      <a href="/ganaderia" class={mobileLinkClass("/ganaderia")}>
        Ganaderia
      </a>

      <a href="/agricultura" class={mobileLinkClass("/agricultura")}>
        Agricultura
      </a>

      <a
        href="/contacto"
        class={`mt-1 inline-flex items-center justify-center rounded-full px-5 py-3 text-sm font-semibold no-underline transition ${
          isActive("/contacto")
            ? "bg-amber-300 text-stone-950"
            : "bg-stone-950 text-white hover:bg-stone-800 active:translate-y-[1px]"
        }`}
      >
        Contacto
      </a>
    </nav>
  </div>
</header>
