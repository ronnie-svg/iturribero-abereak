---
import type { Locale } from "../../../i18n";

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? "es";

const copy = {
  es: {
    eyebrow: "Nuestro enfoque",
    title: "Campo trabajado con criterio, calma y continuidad.",
    description:
      "Ganadería y agricultura conviven en una misma explotación familiar. Lo importante no es hacer más ruido, sino sostener una forma de trabajar que cuide animales, tierra y campañas.",
    pillars: [
      {
        title: "Ganado",
        description:
          "Seguimiento diario, bienestar animal y una manera de trabajar basada en la constancia.",
      },
      {
        title: "Tierra",
        description:
          "Cada campaña se planifica con respeto por el suelo, el ritmo del clima y el trabajo bien hecho.",
      },
      {
        title: "Familia",
        description:
          "Proyecto sostenido por experiencia, arraigo local y decisiones pensadas a largo plazo.",
      },
    ],
  },
  eu: {
    eyebrow: "Gure ikuspegia",
    title: "Irizpidez, patxadaz eta jarraitutasunez landutako lurra.",
    description:
      "Gure familia-ustiategian, abeltzaintza eta nekazaritza elkarrekin bizi dira. Guretzat garrantzitsuena ez da zarata egitea, baizik eta animaliak, lurra eta urtaroak errespetatzen dituen lan egiteko moduari eustea.",
    pillars: [
      {
        title: "Azienda",
        description:
          "Eguneroko jarraipena, animalien ongizatea eta etengabeko lan egiteko modu bat.",
      },
      {
        title: "Lurra",
        description:
          "Sasoi bakoitza lurra, eguraldiaren erritmoa eta ondo egindako lana errespetatuz planifikatzen da.",
      },
      {
        title: "Familia",
        description:
          "Esperientzian, tokiko erroetan eta epe luzerako erabakietan oinarritutako proiektua.",
      },
    ],
  },
}[locale];
---

<section class="border-t border-stone-200 bg-stone-50">
  <div class="mx-auto max-w-7xl px-6 py-18 md:px-8 md:py-24">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.9fr)] lg:items-start">
      <div class="max-w-3xl">
        <p class="eyebrow text-stone-500">
          {copy.eyebrow}
        </p>

        <h2 class="mt-5 text-4xl font-semibold leading-tight tracking-[-0.04em] text-stone-950 md:text-6xl">
          {copy.title}
        </h2>

        <p class="mt-6 max-w-2xl text-base leading-7 text-stone-600 md:text-lg">
          {copy.description}
        </p>
      </div>

      <div class="grid gap-4">
        {copy.pillars.map((pillar, index) => (
          <article class="rounded-[1.75rem] border border-stone-200 bg-white p-6 shadow-[0_24px_60px_-42px_rgba(28,25,23,0.35)]">
            <div class="flex items-start gap-4">
              <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-amber-100 text-sm font-semibold text-amber-900">
                0{index + 1}
              </span>

              <div>
                <h3 class="text-xl font-semibold text-stone-950">
                  {pillar.title}
                </h3>
                <p class="mt-3 text-sm leading-6 text-stone-600 md:text-base">
                  {pillar.description}
                </p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
