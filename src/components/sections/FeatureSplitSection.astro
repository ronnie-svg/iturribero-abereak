<section class="w-full">

  <!-- GANADERÍA -->
  <a href="/ganaderia" class="group block">
    <div class="relative h-80 md:h-105 overflow-hidden">

      <img
        src="/vaca_primer-plano.jpg"
        alt="Ganadería en Iturribero Abereak"
        class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-700"
      />

      <!-- Overlay principal -->
      <div class="absolute inset-0 bg-linear-to-r from-black/70 via-black/30 to-transparent"></div>

      <!-- Diagonal más sutil -->
      <div class="absolute inset-0 hidden md:block">
        <div class="absolute top-0 left-0 h-full w-[55%] bg-black/20 
        [clip-path:polygon(0_0,75%_0,55%_100%,0_100%)]"></div>
      </div>

      <!-- Contenido -->
      <div class="relative z-10 h-full flex items-center px-6 md:px-16 lg:px-24">
        <div class="max-w-md text-white">

          <p class="uppercase tracking-[0.25em] text-yellow-200 text-xs mb-3">
            Ganadería
          </p>

          <h2 class="text-2xl md:text-4xl font-semibold leading-tight">
            Bienestar y cuidado del ganado
          </h2>

          <p class="mt-4 text-white/90 leading-relaxed text-sm md:text-base">
            Manejo responsable, seguimiento continuo y enfoque en calidad.
          </p>

          <span class="mt-6 inline-flex items-center gap-2 text-sm font-semibold group-hover:gap-3 transition-all">
            Ver ganadería →
          </span>

        </div>
      </div>
    </div>
  </a>

  <!-- AGRICULTURA -->
  <a href="/agricultura" class="group block">
    <div class="relative h-80 md:h-105 overflow-hidden">

      <img
        src="/cebada.jpg"
        alt="Agricultura en Iturribero Abereak"
        class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-700"
      />

      <!-- Overlay -->
      <div class="absolute inset-0 bg-linear-to-l from-black/70 via-black/30 to-transparent"></div>

      <!-- Diagonal sutil -->
      <div class="absolute inset-0 hidden md:block">
        <div class="absolute top-0 right-0 h-full w-[55%] bg-black/20 
        [clip-path:polygon(25%_0,100%_0,100%_100%,45%_100%)]"></div>
      </div>

      <!-- Contenido -->
      <div class="relative z-10 h-full flex items-center justify-end px-6 md:px-16 lg:px-24">
        <div class="max-w-md text-white md:text-right">

          <p class="uppercase tracking-[0.25em] text-yellow-200 text-xs mb-3">
            Agricultura
          </p>

          <h2 class="text-2xl md:text-4xl font-semibold leading-tight">
            Cultivo y trabajo de campo
          </h2>

          <p class="mt-4 text-white/90 leading-relaxed text-sm md:text-base">
            Producción agrícola respetando los ciclos naturales y el suelo.
          </p>

          <span class="mt-6 inline-flex items-center gap-2 text-sm font-semibold group-hover:gap-3 transition-all">
            Ver agricultura →
          </span>

        </div>
      </div>
    </div>
  </a>

</section>