<section class="w-full bg-slate-100 border-t border-gray-200">
  <div class="max-w-7xl mx-auto px-8 py-20">
    <div class="max-w-3xl">
      <p class="text-xs uppercase tracking-[0.35em] text-gray-400 mb-4">
        Generaciones
      </p>

      <h2 class="text-4xl md:text-5xl font-semibold leading-tight text-gray-900">
        Un proyecto que ha pasado
        <br />
        de generación en generación.
      </h2>
    </div>

    <div class="mt-14">
      <div class="relative">
        <div class="absolute left-0 right-0 top-5 h-px bg-gray-300"></div>

        <div class="relative grid md:grid-cols-3 gap-10">
          <button type="button" class="generation-tab text-left group" data-generation="1">
            <span class="generation-dot flex h-10 w-10 items-center justify-center rounded-full border border-gray-900 bg-gray-900 text-sm font-semibold text-white transition">
              1
            </span>
            <div class="mt-10">
              <h3 class="text-lg font-semibold text-gray-900">Primera generación</h3>
              <p class="mt-3 text-gray-600 leading-relaxed">
                El origen del proyecto: trabajo diario, oficio y una manera de vivir el campo desde dentro.
              </p>
            </div>
          </button>

          <button type="button" class="generation-tab text-left group" data-generation="2">
            <span class="generation-dot flex h-10 w-10 items-center justify-center rounded-full border border-gray-300 bg-white text-sm font-semibold text-gray-900 transition">
              2
            </span>
            <div class="mt-10">
              <h3 class="text-lg font-semibold text-gray-900">Segunda generación</h3>
              <p class="mt-3 text-gray-600 leading-relaxed">
                Continuidad y evolución: mantener la base familiar adaptándose a cada campaña y necesidad.
              </p>
            </div>
          </button>

          <button type="button" class="generation-tab text-left group" data-generation="3">
            <span class="generation-dot flex h-10 w-10 items-center justify-center rounded-full border border-gray-300 bg-white text-sm font-semibold text-gray-900 transition">
              3
            </span>
            <div class="mt-10">
              <h3 class="text-lg font-semibold text-gray-900">Tercera generación</h3>
              <p class="mt-3 text-gray-600 leading-relaxed">
                El presente: una explotación pequeña, cercana y responsable.
              </p>
            </div>
          </button>
        </div>
      </div>

      <div class="mt-14 rounded-3xl border border-gray-200 bg-white overflow-hidden shadow-sm">
        <div class="grid lg:grid-cols-2">
          <div class="relative min-h-[320px]">
            <img
              id="generation-image"
              src="/tierra.jpg"
              alt="Primera generación de Iturribero Abereak"
              class="absolute inset-0 h-full w-full object-cover transition duration-300"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-black/5 to-transparent"></div>
          </div>

          <div class="p-8 md:p-10 flex flex-col justify-center">
            <div id="generation-content-1" class="generation-content">
              <p class="text-xs uppercase tracking-[0.35em] text-gray-400 mb-3">Primera generación</p>
              <h3 class="text-2xl md:text-3xl font-semibold text-gray-900">Los inicios del proyecto</h3>
              <p class="mt-4 text-gray-600 leading-relaxed">
                Todo empieza con el trabajo diario, el conocimiento del campo y una forma de entender la vida ligada al esfuerzo, la constancia y el arraigo al entorno.
              </p>
            </div>

            <div id="generation-content-2" class="generation-content hidden">
              <p class="text-xs uppercase tracking-[0.35em] text-gray-400 mb-3">Segunda generación</p>
              <h3 class="text-2xl md:text-3xl font-semibold text-gray-900">Continuidad con capacidad de adaptación</h3>
              <p class="mt-4 text-gray-600 leading-relaxed">
                La segunda generación mantiene viva la base familiar, incorporando ajustes y decisiones para dar continuidad al proyecto.
              </p>
            </div>

            <div id="generation-content-3" class="generation-content hidden">
              <p class="text-xs uppercase tracking-[0.35em] text-gray-400 mb-3">Tercera generación</p>
              <h3 class="text-2xl md:text-3xl font-semibold text-gray-900">El presente de Iturribero Abereak</h3>
              <p class="mt-4 text-gray-600 leading-relaxed">
                Hoy el proyecto se traduce en una explotación pequeña, cercana y responsable, conectada al territorio.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    const generationTabs = document.querySelectorAll(".generation-tab");
    const generationDots = document.querySelectorAll(".generation-dot");
    const generationContents = document.querySelectorAll(".generation-content");
    const generationImage = document.getElementById("generation-image");

    const generationData = {
      1: { image: "/tierra.jpg", alt: "Primera generación de Iturribero Abereak" },
      2: { image: "/camino.jpg", alt: "Segunda generación de Iturribero Abereak" },
      3: { image: "/asturiana.jpg", alt: "Tercera generación de Iturribero Abereak" }
    };

    generationTabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const generation = tab.dataset.generation;

        generationDots.forEach((dot) => {
          dot.classList.remove("bg-gray-900", "text-white", "border-gray-900");
          dot.classList.add("bg-white", "text-gray-900", "border-gray-300");
        });

        const activeDot = tab.querySelector(".generation-dot");
        activeDot.classList.remove("bg-white", "text-gray-900", "border-gray-300");
        activeDot.classList.add("bg-gray-900", "text-white", "border-gray-900");

        generationContents.forEach((content) => content.classList.add("hidden"));
        document.getElementById(`generation-content-${generation}`)?.classList.remove("hidden");

        if (generationImage && generationData[generation]) {
          generationImage.setAttribute("src", generationData[generation].image);
          generationImage.setAttribute("alt", generationData[generation].alt);
        }
      });
    });
  </script>
</section>