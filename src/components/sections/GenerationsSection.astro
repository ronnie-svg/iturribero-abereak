---
import { Image } from "astro:assets";
import tierraImg from "@/assets/agricultura/tierra.jpg";
import caminoImg from "@/assets/agricultura/camino.jpg";
import asturianaImg from "@/assets/ganaderia/asturiana.jpg";
import type { Locale } from "../../i18n";

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? "es";

const copy = {
  es: {
    eyebrow: "Generaciones",
    title: ["Un proyecto que evoluciona", "sin perder la raíz"],
    description:
      "Tres generaciones unidas por una misma manera de entender el campo: trabajo diario, continuidad familiar y una relación directa con el territorio.",
    brand: "Iturribero Abereak",
    indicators: ["Primera", "Segunda", "Tercera"],
    contents: [
      {
        eyebrow: "Primera generación",
        title: "Los inicios del proyecto",
        lead:
          "Todo empieza con el trabajo diario, el conocimiento del campo y una forma de entender la vida ligada al esfuerzo, la constancia y el arraigo al entorno.",
        text:
          "Esta etapa representa la base sobre la que se construye todo lo demás: oficio, experiencia y una relación directa con la tierra.",
      },
      {
        eyebrow: "Segunda generación",
        title: "Continuidad con capacidad de adaptación",
        lead:
          "La segunda generación mantiene viva la base familiar, incorporando ajustes y decisiones que permiten dar continuidad al proyecto en un contexto cambiante.",
        text:
          "Es una etapa de consolidación: seguir adelante sin perder la esencia, pero sabiendo evolucionar con cada campaña y necesidad.",
      },
      {
        eyebrow: "Tercera generación",
        title: "El presente de Iturribero Abereak",
        lead:
          "Hoy, el proyecto se traduce en una explotación pequeña, cercana y responsable, con vacas de carne y cultivos destinados a su alimentación.",
        text:
          "Una forma de trabajar con identidad propia, conectada al territorio y sostenida por una historia familiar que sigue viva.",
      },
    ],
    footerTitle: "Legado",
    footerText:
      "Cada generación suma experiencia, decisiones y una forma propia de seguir vinculados al campo.",
  },
  eu: {
    eyebrow: "Belaunaldiak",
    title: ["Eboluzioan dagoen proiektua,", "sustraiak galdu gabe."],
    description:
      "Hiru belaunaldi landa ulertzeko modu berean bilduta: familia-jarraitutasuna eta lurraldearekiko harreman zuzena.",
    brand: "Iturribero Abereak",
    indicators: ["Lehena", "Bigarrena", "Hirugarrena"],
    contents: [
      {
        eyebrow: "Lehen belaunaldia",
        title: "Hasierak",
        lead:
          "Ofizioaren oinarriak, lurraren ezagutza eta irmotasuna.",
        text:
          "Dena eraiki zuen esperientzia.",
      },
      {
        eyebrow: "Bigarren belaunaldia",
        title: "Egokitzapena",
        lead:
          "Familia-oinarria bizirik mantenduz, proiektua garai berrietara eta testuinguru aldakorretara egokitzea.",
        text:
          "",
      },
      {
        eyebrow: "Hirugarren belaunaldia",
        title: "Oraina",
        lead:
          "Iturribero Abereaken gaur egungo errealitatea: ustiapen hurbila, arduratsua eta nortasun propio duna.",
        text:
          "",
      },
    ],
    footerTitle: "Ondarea",
    footerText:
      "Belaunaldi bakoitzak bere esperientzia eta landari lotzeko modu propioa gehitu dio gure familiari.",
  },
}[locale];
---

<section class="w-full bg-white">
  <div class="mx-auto max-w-7xl px-6 py-16 md:px-8 md:py-18">
    <div class="grid gap-8 lg:grid-cols-12 lg:items-end">
      <div class="lg:col-span-7">
        <p class="eyebrow mb-5">
          {copy.eyebrow}
        </p>

        <h2 class="section-title">
          {copy.title[0]}
          <span class="block">{copy.title[1]}</span>
        </h2>
      </div>

      <div class="lg:col-span-5">
        <p class="section-copy max-w-xl">
          {copy.description}
        </p>
      </div>
    </div>

    <div class="mt-12 overflow-hidden rounded-4xl border border-gray-200 bg-gray-950">
      <div class="flex flex-col lg:grid lg:min-h-[42rem] lg:grid-cols-12">
        <div class="relative min-h-[15rem] w-full sm:min-h-[19rem] lg:col-span-7 lg:min-h-full">
          <Image
            id="generation-image-1"
            src={tierraImg}
            alt="Primera generacion de Iturribero Abereak"
            class="generation-image is-active"
            sizes="(min-width: 1024px) 58vw, 100vw"
            loading="eager"
          />

          <Image
            id="generation-image-2"
            src={caminoImg}
            alt="Segunda generacion de Iturribero Abereak"
            class="generation-image"
            sizes="(min-width: 1024px) 58vw, 100vw"
            loading="lazy"
          />

          <Image
            id="generation-image-3"
            src={asturianaImg}
            alt="Tercera generacion de Iturribero Abereak"
            class="generation-image"
            sizes="(min-width: 1024px) 58vw, 100vw"
            loading="lazy"
          />

          <div class="absolute inset-0 bg-linear-to-t from-black/45 via-black/12 to-transparent lg:bg-linear-to-r lg:from-transparent lg:via-transparent lg:to-black/10"></div>

          <div class="absolute bottom-4 left-4 md:bottom-8 md:left-8">
            <div class="inline-flex items-center gap-3 rounded-full bg-black/30 px-4 py-2 text-[11px] text-white/85 backdrop-blur-sm md:text-sm">
              <span class="uppercase tracking-[0.3em]">{copy.brand}</span>
            </div>
          </div>
        </div>

        <div class="relative w-full bg-gray-950 text-white lg:col-span-5">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.06),transparent_40%)]"></div>

          <div class="relative flex h-full flex-col justify-between p-5 sm:p-6 md:p-8 lg:p-10">
            <div>
              <div class="generation-indicators no-scrollbar -mx-1 overflow-x-auto px-1 pb-2">
                <button class="generation-indicator is-active" data-generation="1" type="button">
                  <span class="generation-indicator__number">1</span>
                  <span class="generation-indicator__label">{copy.indicators[0]}</span>
                </button>

                <button class="generation-indicator" data-generation="2" type="button">
                  <span class="generation-indicator__number">2</span>
                  <span class="generation-indicator__label">{copy.indicators[1]}</span>
                </button>

                <button class="generation-indicator" data-generation="3" type="button">
                  <span class="generation-indicator__number">3</span>
                  <span class="generation-indicator__label">{copy.indicators[2]}</span>
                </button>
              </div>

              <div id="generation-content-1" class="generation-content is-active">
                <p class="generation-content__eyebrow">{copy.contents[0].eyebrow}</p>

                <h3 class="generation-content__title">
                  {copy.contents[0].title}
                </h3>

                <p class="generation-content__text generation-content__text--lead">
                  {copy.contents[0].lead}
                </p>

                {copy.contents[0].text && (
                  <p class="generation-content__text">
                    {copy.contents[0].text}
                  </p>
                )}
              </div>

              <div id="generation-content-2" class="generation-content">
                <p class="generation-content__eyebrow">{copy.contents[1].eyebrow}</p>

                <h3 class="generation-content__title">
                  {copy.contents[1].title}
                </h3>

                <p class="generation-content__text generation-content__text--lead">
                  {copy.contents[1].lead}
                </p>

                {copy.contents[1].text && (
                  <p class="generation-content__text">
                    {copy.contents[1].text}
                  </p>
                )}
              </div>

              <div id="generation-content-3" class="generation-content">
                <p class="generation-content__eyebrow">{copy.contents[2].eyebrow}</p>

                <h3 class="generation-content__title">
                  {copy.contents[2].title}
                </h3>

                <p class="generation-content__text generation-content__text--lead">
                  {copy.contents[2].lead}
                </p>

                {copy.contents[2].text && (
                  <p class="generation-content__text">
                    {copy.contents[2].text}
                  </p>
                )}
              </div>
            </div>

            <div class="generation-stage__footer">
              <div class="generation-stage__footer-top">
                <span>{copy.footerTitle}</span>
                <span></span>
              </div>

              <p>
                {copy.footerText}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    (() => {
      const section = document.currentScript?.closest("section");
      if (!section) return;

      const contents = section.querySelectorAll(".generation-content");
      const images = section.querySelectorAll(".generation-image");
      const indicators = section.querySelectorAll(".generation-indicator");

      const activateGeneration = (id) => {
        contents.forEach((content) => {
          content.classList.toggle("is-active", content.id === `generation-content-${id}`);
        });

        images.forEach((image) => {
          image.classList.toggle("is-active", image.id === `generation-image-${id}`);
        });

        indicators.forEach((indicator) => {
          indicator.classList.toggle("is-active", indicator.dataset.generation === id);
          indicator.setAttribute(
            "aria-pressed",
            indicator.dataset.generation === id ? "true" : "false"
          );
        });
      };

      indicators.forEach((indicator) => {
        indicator.addEventListener("click", () => {
          activateGeneration(indicator.dataset.generation);
        });
      });
    })();
  </script>

  <style>
    .generation-image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0;
      transform: scale(1.04);
      transition:
        opacity 700ms ease,
        transform 900ms ease;
      pointer-events: none;
    }

    .generation-image.is-active {
      opacity: 1;
      transform: scale(1);
    }

    .generation-indicators {
      display: flex;
      gap: 0.55rem;
      margin-bottom: 1.5rem;
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x proximity;
    }

    .generation-indicator {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      min-height: 2.6rem;
      padding: 0.4rem 0.75rem 0.4rem 0.4rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: transparent;
      color: rgba(255, 255, 255, 0.66);
      transition: all 220ms ease;
      font-size: 0.82rem;
      flex: 0 0 auto;
      scroll-snap-align: start;
    }

    .generation-indicator__number {
      display: inline-flex;
      width: 1.55rem;
      height: 1.55rem;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.08);
      font-size: 0.78rem;
      font-weight: 600;
    }

    .generation-indicator__label {
      font-size: 0.76rem;
      font-weight: 600;
      letter-spacing: 0.01em;
      white-space: nowrap;
    }

    .generation-indicator.is-active {
      border-color: rgba(255, 255, 255, 0.24);
      background: rgba(255, 255, 255, 0.08);
      color: white;
    }

    .generation-indicator.is-active .generation-indicator__number {
      background: white;
      color: #111827;
    }

    .generation-content {
      display: none;
      opacity: 0;
      transform: translateY(8px);
      transition: opacity 350ms ease, transform 350ms ease;
    }

    .generation-content.is-active {
      display: block;
      opacity: 1;
      transform: translateY(0);
    }

    .generation-content__eyebrow {
      margin: 0 0 0.7rem;
      color: rgba(255, 255, 255, 0.5);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.32em;
    }

    .generation-content__title {
      margin: 0;
      color: white;
      font-size: clamp(1.6rem, 5.6vw, 3rem);
      line-height: 1.04;
      font-weight: 600;
      max-width: 14ch;
      text-wrap: balance;
    }

    .generation-content__text {
      margin: 0.9rem 0 0;
      color: rgba(255, 255, 255, 0.66);
      line-height: 1.65;
      font-size: 0.95rem;
    }

    .generation-content__text--lead {
      margin-top: 1rem;
      color: rgba(255, 255, 255, 0.8);
      font-size: 0.98rem;
    }

    .generation-stage__footer {
      margin-top: 1.8rem;
      padding-top: 1.25rem;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .generation-stage__footer-top {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      color: rgba(255, 255, 255, 0.58);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.3em;
    }

    .generation-stage__footer-top span:last-child {
      display: block;
      height: 1px;
      flex: 1;
      background: rgba(255, 255, 255, 0.1);
    }

    .generation-stage__footer p {
      margin: 0.85rem 0 0;
      max-width: 32rem;
      color: rgba(255, 255, 255, 0.56);
      line-height: 1.6;
      font-size: 0.9rem;
    }

    @media (min-width: 640px) {
      .generation-indicators {
        margin-bottom: 1.8rem;
      }

      .generation-indicator {
        min-height: 2.8rem;
        padding: 0.45rem 0.9rem 0.45rem 0.45rem;
      }

      .generation-content__text,
      .generation-content__text--lead {
        font-size: 1rem;
      }

      .generation-stage__footer {
        margin-top: 2.2rem;
        padding-top: 1.4rem;
      }
    }

    @media (min-width: 1024px) {
      .generation-indicators {
        margin-bottom: 2rem;
      }

      .generation-stage__footer {
        margin-top: 2.5rem;
        padding-top: 1.5rem;
      }

      .generation-stage__footer p {
        font-size: 0.95rem;
      }
    }
  </style>
</section>
