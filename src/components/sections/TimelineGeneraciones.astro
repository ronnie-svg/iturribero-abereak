<section class="w-full bg-white border-t border-gray-200">
  <div class="max-w-7xl mx-auto px-6 md:px-8 py-16 md:py-24">
    <!-- Header -->
    <div class="grid gap-8 lg:grid-cols-12 lg:items-end">
      <div class="lg:col-span-7">
        <p class="text-xs uppercase tracking-[0.35em] text-gray-400 mb-5">
          Generaciones
        </p>

        <h2 class="text-3xl md:text-5xl font-semibold leading-tight text-gray-900">
          Un proyecto que evoluciona
          <span class="block">sin perder la raíz</span>
        </h2>
      </div>

      <div class="lg:col-span-5">
        <p class="text-base md:text-lg leading-relaxed text-gray-600 max-w-xl">
          Tres generaciones unidas por una misma manera de entender el campo:
          trabajo diario, continuidad familiar y una relación directa con el territorio.
        </p>
      </div>
    </div>

    <!-- Selector -->
    <div class="mt-10 md:mt-12">
      <div
        class="generation-tabs flex gap-3 overflow-x-auto pb-2"
        role="tablist"
        aria-label="Generaciones"
      >
        <button
          type="button"
          class="generation-tab shrink-0 rounded-full border border-gray-900 bg-gray-900 px-5 py-2.5 text-sm font-medium text-white transition"
          data-generation="1"
          aria-selected="true"
        >
          1ª Generación
        </button>

        <button
          type="button"
          class="generation-tab shrink-0 rounded-full border border-gray-300 bg-white px-5 py-2.5 text-sm font-medium text-gray-700 transition"
          data-generation="2"
          aria-selected="false"
        >
          2ª Generación
        </button>

        <button
          type="button"
          class="generation-tab shrink-0 rounded-full border border-gray-300 bg-white px-5 py-2.5 text-sm font-medium text-gray-700 transition"
          data-generation="3"
          aria-selected="false"
        >
          3ª Generación
        </button>
      </div>
    </div>

    <!-- Stage -->
    <div class="mt-8 md:mt-10 overflow-hidden rounded-4xl border border-gray-200 bg-gray-950">
      <div class="grid lg:grid-cols-12 min-h-140">
        <!-- Imagen -->
        <div class="relative lg:col-span-7 min-h-75 lg:min-h-full">
          <img
            id="generation-image-1"
            src="/tierra.jpg"
            alt="Primera generación de Iturribero Abereak"
            class="generation-image absolute inset-0 h-full w-full object-cover opacity-100 scale-100 transition-all duration-700 ease-out"
          />

          <img
            id="generation-image-2"
            src="/camino.jpg"
            alt="Segunda generación de Iturribero Abereak"
            class="generation-image pointer-events-none absolute inset-0 h-full w-full object-cover opacity-0 scale-[1.03] transition-all duration-700 ease-out"
          />

          <img
            id="generation-image-3"
            src="/asturiana.jpg"
            alt="Tercera generación de Iturribero Abereak"
            class="generation-image pointer-events-none absolute inset-0 h-full w-full object-cover opacity-0 scale-[1.03] transition-all duration-700 ease-out"
          />

          <div class="absolute inset-0 bg-linear-to-t from-black/35 via-black/10 to-transparent lg:bg-linear-to-r lg:from-transparent lg:via-transparent lg:to-black/10"></div>

          <div class="absolute left-6 bottom-6 md:left-8 md:bottom-8">
            <div class="inline-flex items-center gap-3 rounded-full bg-black/30 px-4 py-2 text-white/85 backdrop-blur-sm">
              <span class="text-xs uppercase tracking-[0.3em]">Iturribero Abereak</span>
            </div>
          </div>
        </div>

        <!-- Panel -->
        <div class="relative lg:col-span-5 bg-gray-950 text-white">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.06),transparent_40%)]"></div>

          <div class="relative h-full flex flex-col justify-between p-6 md:p-8 lg:p-10">
            <div>
              <div
                id="generation-content-1"
                class="generation-content opacity-100 translate-y-0 transition-all duration-500"
              >
                <p class="text-xs uppercase tracking-[0.35em] text-white/50 mb-3">
                  Primera generación
                </p>

                <h3 class="text-2xl md:text-4xl font-semibold leading-tight text-white">
                  Los inicios del proyecto
                </h3>

                <p class="mt-5 text-white/75 leading-relaxed text-base md:text-lg">
                  Todo empieza con el trabajo diario, el conocimiento del campo y una
                  forma de entender la vida ligada al esfuerzo, la constancia y el
                  arraigo al entorno.
                </p>

                <p class="mt-4 text-white/65 leading-relaxed">
                  Esta etapa representa la base sobre la que se construye todo lo demás:
                  oficio, experiencia y una relación directa con la tierra.
                </p>
              </div>

              <div
                id="generation-content-2"
                class="generation-content hidden opacity-0 translate-y-2 transition-all duration-500"
              >
                <p class="text-xs uppercase tracking-[0.35em] text-white/50 mb-3">
                  Segunda generación
                </p>

                <h3 class="text-2xl md:text-4xl font-semibold leading-tight text-white">
                  Continuidad con capacidad de adaptación
                </h3>

                <p class="mt-5 text-white/75 leading-relaxed text-base md:text-lg">
                  La segunda generación mantiene viva la base familiar, incorporando
                  ajustes y decisiones que permiten dar continuidad al proyecto en un
                  contexto cambiante.
                </p>

                <p class="mt-4 text-white/65 leading-relaxed">
                  Es una etapa de consolidación: seguir adelante sin perder la esencia,
                  pero sabiendo evolucionar con cada campaña y necesidad.
                </p>
              </div>

              <div
                id="generation-content-3"
                class="generation-content hidden opacity-0 translate-y-2 transition-all duration-500"
              >
                <p class="text-xs uppercase tracking-[0.35em] text-white/50 mb-3">
                  Tercera generación
                </p>

                <h3 class="text-2xl md:text-4xl font-semibold leading-tight text-white">
                  El presente de Iturribero Abereak
                </h3>

                <p class="mt-5 text-white/75 leading-relaxed text-base md:text-lg">
                  Hoy, el proyecto se traduce en una explotación pequeña, cercana y
                  responsable, con vacas de carne y cultivos destinados a su alimentación.
                </p>

                <p class="mt-4 text-white/65 leading-relaxed">
                  Una forma de trabajar con identidad propia, conectada al territorio y
                  sostenida por una historia familiar que sigue viva.
                </p>
              </div>
            </div>

            <div class="mt-10 pt-6 border-t border-white/10">
              <div class="flex items-center gap-3 text-white/60">
                <span class="text-xs uppercase tracking-[0.3em]">Legado</span>
                <span class="h-px flex-1 bg-white/10"></span>
              </div>

              <p class="mt-4 text-sm md:text-base text-white/55 leading-relaxed max-w-md">
                Cada generación suma experiencia, decisiones y una forma propia de
                seguir vinculados al campo.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    (() => {
      const tabs = document.querySelectorAll(".generation-tab");
      const contents = document.querySelectorAll(".generation-content");
      const images = document.querySelectorAll(".generation-image");

      const activateGeneration = (id) => {
        tabs.forEach((tab) => {
          const isActive = tab.dataset.generation === id;
          tab.setAttribute("aria-selected", isActive ? "true" : "false");

          tab.classList.toggle("bg-gray-900", isActive);
          tab.classList.toggle("border-gray-900", isActive);
          tab.classList.toggle("text-white", isActive);

          tab.classList.toggle("bg-white", !isActive);
          tab.classList.toggle("border-gray-300", !isActive);
          tab.classList.toggle("text-gray-700", !isActive);
        });

        contents.forEach((content) => {
          const isActive = content.id === `generation-content-${id}`;

          if (isActive) {
            content.classList.remove("hidden", "opacity-0", "translate-y-2");
            content.classList.add("opacity-100", "translate-y-0");
          } else {
            content.classList.remove("opacity-100", "translate-y-0");
            content.classList.add("hidden", "opacity-0", "translate-y-2");
          }
        });

        images.forEach((image) => {
          const isActive = image.id === `generation-image-${id}`;

          if (isActive) {
            image.classList.remove("opacity-0", "scale-[1.03]", "pointer-events-none");
            image.classList.add("opacity-100", "scale-100");
          } else {
            image.classList.remove("opacity-100", "scale-100");
            image.classList.add("opacity-0", "scale-[1.03]", "pointer-events-none");
          }
        });
      };

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          activateGeneration(tab.dataset.generation);
        });
      });
    })();
  </script>
</section>