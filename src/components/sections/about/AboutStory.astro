<section class="w-full bg-white">
  <div class="max-w-7xl mx-auto px-6 md:px-8 py-20 md:py-28 space-y-28">

    <!-- BLOQUE 1 -->
    <div class="relative js-reveal-right">

      <!-- Imagen más panorámica -->
      <div class="relative h-60 md:h-80 lg:h-95 rounded-4xl overflow-hidden">
        <img
          src="/camino.jpg"
          class="absolute inset-0 w-full h-full object-cover scale-[1.02]"
        />
        <div class="absolute inset-0 bg-black/25"></div>
      </div>

      <!-- Card -->
      <div class="reveal-card reveal-card--right">
        <p class="eyebrow">Nuestra manera de hacer</p>

        <h3 class="title">
          Menos ruido.
          <span>Más campo.</span>
        </h3>

        <p class="text">
          Trabajo constante, decisiones responsables y una forma de hacer las cosas
          que se construye día a día.
        </p>
      </div>

    </div>

    <!-- BLOQUE 2 -->
    <div class="relative js-reveal-left">

      <!-- Imagen más panorámica -->
      <div class="relative h-60 md:h-80 lg:h-95 rounded-4xl overflow-hidden">
        <img
          src="/vacas.jpg"
          class="absolute inset-0 w-full h-full object-cover scale-[1.02]"
        />
        <div class="absolute inset-0 bg-black/25"></div>
      </div>

      <!-- Card -->
      <div class="reveal-card reveal-card--left">
        <p class="eyebrow">Nuestra filosofía</p>

        <h3 class="title">
          Hacer las cosas bien,
          <span>sin atajos</span>
        </h3>

        <p class="text">
          Cuidar el ganado, respetar el campo y mantener un equilibrio real entre ambos.
        </p>
      </div>

    </div>

  </div>

  <!-- ANIMACIÓN -->
  <script is:inline>
    (() => {
      const elements = document.querySelectorAll(".js-reveal-right, .js-reveal-left");

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
            }
          });
        },
        { threshold: 0.3 }
      );

      elements.forEach(el => observer.observe(el));
    })();
  </script>
</section>

<style>
.reveal-card {
  position: absolute;
  bottom: -4rem; /* MÁS DENTRO DE LA IMAGEN */
  width: min(100%, 28rem);

  background: rgba(255, 255, 255, 0.75); /* MÁS TRANSPARENTE */
  backdrop-filter: blur(14px); /* MÁS SUAVE Y PRO */

  border-radius: 1.5rem;
  padding: 1.75rem;

  border: 1px solid rgba(255, 255, 255, 0.4);

  box-shadow: 0 20px 50px rgba(0, 0, 0, 0.12);

  opacity: 0;
  transition: all 0.7s cubic-bezier(0.22, 1, 0.36, 1);
}

/* POSICIÓN MÁS INTERIOR */
.reveal-card--right {
  right: 5rem;
  transform: translateX(110px) translateY(50px);
}

.reveal-card--left {
  left: 5rem;
  transform: translateX(-110px) translateY(50px);
}

/* ACTIVO */
.is-visible .reveal-card {
  opacity: 1;
  transform: translateX(0) translateY(0);
}

  /* TEXTOS */
  .eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: black;
    margin-bottom: 0.6rem;
  }

  .title {
    font-size: clamp(1.6rem, 2.8vw, 2.2rem);
    font-weight: 600;
    line-height: 1.05;
    color: #111827;
  }

  .title span {
    display: block;
  }

  .text {
    margin-top: 0.9rem;
    color: #4b5563;
    line-height: 1.6;
    font-size: 0.9rem;
  }

  /* MOBILE */
  @media (max-width: 768px) {
    .reveal-card {
      position: relative;
      bottom: auto;
      left: auto;
      right: auto;
      transform: translateY(30px);
      margin-top: -3.5rem;
    }

    .is-visible .reveal-card {
      transform: translateY(0);
    }
  }
</style>