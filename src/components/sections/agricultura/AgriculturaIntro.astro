---
import { Image } from "astro:assets";
import tierra from "@/assets/agricultura/tierra.jpg";
import type { Locale } from "../../../i18n";

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? "es";

const copy = {
  es: {
    eyebrow: "Proceso de trabajo",
    title: ["Agricultura pensada", "como una secuencia real."],
    description:
      "Aqu\u00ED no todo empieza y termina en la siembra. Hay lectura del terreno, elecci\u00F3n del momento, trabajo con maquinaria y una idea clara de hacia d\u00F3nde va cada cultivo dentro de la explotaci\u00F3n.",
    crops: ["Trigo", "Cebada", "Avena", "Ma\u00EDz", "Colza", "Veza", "Hierba"],
    imageAlt: "Detalle del suelo agr\u00EDcola en Iturribero Abereak",
    sideTitleA: "Ventanas de trabajo",
    sideTextA:
      "El clima y el estado del terreno deciden cu\u00E1ndo conviene entrar, esperar o acelerar una fase concreta de la campa\u00F1a.",
    sideTitleB: "Destino del cultivo",
    sideTextB:
      "Parte del cereal y del forraje vuelve a la propia explotaci\u00F3n, reforzando un ciclo de trabajo m\u00E1s coherente y autosostenido.",
    phases: [
      {
        step: "01",
        title: "Leer el terreno",
        description:
          "Antes de sembrar, el suelo, la humedad y las condiciones de la campa\u00F1a marcan la base de trabajo.",
      },
      {
        step: "02",
        title: "Ajustar el calendario",
        description:
          "Cada labor depende del momento oportuno, no de una receta fija repetida a\u00F1o tras a\u00F1o.",
      },
      {
        step: "03",
        title: "Integrar la explotaci\u00F3n",
        description:
          "Lo que se cultiva se relaciona con el resto del proyecto, especialmente con la alimentaci\u00F3n del ganado y con el equilibrio del conjunto.",
      },
    ],
  },
  eu: {
    eyebrow: "Lan-prozesua",
    title: ["Nekazaritza", "sekuentzia bizi gisa ulertua."],
    description:
      "Hemen dena ez da ereintzarekin hasi eta amaitzen. Gure lana lurra irakurtzea da: une egokia aukeratzea, makineria doitzea eta labore bakoitzak ustiapenaren barruan duen helburua argi izatea.",
    crops: ["Garia", "Garagarra", "Oloa", "Artoa", "Koltza", "Zezia", "Belarra"],
    imageAlt: "Iturribero Abereakeko nekazaritza lurzoruaren xehetasuna",
    sideTitleA: "Lan-leihoak",
    sideTextA:
      "Eguraldiak eta lurraren egoerak agintzen dute: noiz sartu, noiz itxaron edo noiz azkartu sasoiko faseak.",
    sideTitleB: "Laborearen helmuga",
    sideTextB:
      "Zerealaren eta bazkaren zati bat ustiapen berera itzultzen da, lan ziklo koherenteago eta autosostengarriagoa indartuz.",
    phases: [
      {
        step: "01",
        title: "Lurra irakurri",
        description:
          "Erein aurretik, lurzoruak, hezetasunak eta sasoiko baldintzek markatzen dute gure bidea.",
      },
      {
        step: "02",
        title: "Egutegia doitu",
        description:
          "Lan bakoitzak bere unea du; ez dugu errezeta finkorik, urtez urteko egoerara egokitzen gara.",
      },
      {
        step: "03",
        title: "Ustiapena integratu",
        description:
          "Landatzen dugun horrek proiektu osoa elikatzen du, bereziki gure abereen beharrak eta baserriaren oreka bermatuz.",
      },
    ],
  },
}[locale];
---

<section class="section-shell bg-white">
  <div class="section-inner">
    <div class="grid gap-12 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start">
      <div class="lg:sticky lg:top-28">
        <p class="eyebrow mb-4">
          {copy.eyebrow}
        </p>

        <h2 class="section-title">
          {copy.title[0]}
          <span class="block">{copy.title[1]}</span>
        </h2>

        <p class="section-copy mt-5 max-w-xl">
          {copy.description}
        </p>

        <div class="chip-row mt-7">
          {copy.crops.map((crop) => (
            <span class="chip">
              {crop}
            </span>
          ))}
        </div>
      </div>

      <div class="space-y-5">
        {copy.phases.map((phase, index) => (
          <article class="grid gap-5 rounded-[2rem] border border-stone-200 bg-stone-50 p-6 shadow-[0_20px_60px_-50px_rgba(28,25,23,0.35)] md:grid-cols-[auto_1fr]">
            <div class="flex items-start gap-4 md:block">
              <span class="inline-flex h-14 w-14 items-center justify-center rounded-[1.25rem] bg-amber-100 text-base font-semibold text-amber-900">
                {phase.step}
              </span>
            </div>

            <div class="grid gap-5 lg:grid-cols-[minmax(0,0.95fr)_minmax(240px,0.85fr)] lg:items-center">
              <div>
                <h3 class="text-2xl font-semibold leading-tight text-stone-950">
                  {phase.title}
                </h3>
                <p class="mt-4 max-w-xl text-sm leading-6 text-stone-600 md:text-base">
                  {phase.description}
                </p>
              </div>

              {index === 0 && (
                <div class="overflow-hidden rounded-[1.5rem] border border-stone-200">
                  <Image
                    src={tierra}
                    alt={copy.imageAlt}
                    class="h-44 w-full object-cover"
                    sizes="(min-width: 1024px) 24vw, 100vw"
                    loading="lazy"
                  />
                </div>
              )}

              {index === 1 && (
                <div class="rounded-[1.5rem] border border-stone-200 bg-white p-5">
                  <p class="text-xs uppercase tracking-[0.28em] text-stone-500">
                    {copy.sideTitleA}
                  </p>
                  <p class="mt-3 text-sm leading-6 text-stone-600">
                    {copy.sideTextA}
                  </p>
                </div>
              )}

              {index === 2 && (
                <div class="rounded-[1.5rem] border border-stone-200 bg-stone-950 p-5 text-white">
                  <p class="text-xs uppercase tracking-[0.28em] text-amber-200/90">
                    {copy.sideTitleB}
                  </p>
                  <p class="mt-3 text-sm leading-6 text-white/74">
                    {copy.sideTextB}
                  </p>
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
