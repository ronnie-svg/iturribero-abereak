---
const cards = [
  {
    title: "Bienestar animal",
    description:
      "Manejo responsable y seguimiento continuo del ganado para garantizar su bienestar.",
    tags: "Cuidado · Rutina · Calidad",
    image: "/vaca_primer-plano.jpg",
  },
  {
    title: "Cuidado del suelo",
    description:
      "Prácticas sostenibles que respetan los ciclos naturales y la fertilidad de la tierra.",
    tags: "Suelo · Sostenibilidad · Campañas",
    image: "/tierra.jpg",
  },
  {
    title: "Calidad y transparencia",
    description:
      "Procesos claros, controlados y en mejora constante para ofrecer confianza.",
    tags: "Claridad · Control · Mejora",
    image: "/vacas.jpg",
  },
];
---

<section class="w-full bg-white border-t border-gray-200">
  <div class="max-w-7xl mx-auto px-6 md:px-8 py-16 md:py-24">

    <!-- Header -->
    <header class="mb-14 md:mb-18 max-w-4xl">
      <p class="eyebrow mb-5">
        Nuestra manera de hacer
      </p>

      <h2 class="text-3xl md:text-5xl font-semibold leading-tight text-gray-900">
        Menos ruido. Más campo.
      </h2>

      <p class="mt-4 text-base md:text-xl leading-relaxed text-gray-600 max-w-2xl">
        Trabajo constante, decisiones responsables y una forma de hacer las cosas
        que se construye cada día, sobre el terreno.
      </p>
    </header>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
      {cards.map((card) => (
        <a
          href="#"
          class="group relative block min-h-[280px] md:min-h-[300px] lg:min-h-[360px] overflow-hidden rounded-[1.75rem] no-underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-black/20"
        >
          <!-- Imagen -->
          <img
            src={card.image}
            alt={card.title}
            class="absolute inset-0 w-full h-full object-cover transition duration-700 ease-out group-hover:scale-[1.04]"
          />

          <!-- Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/35 to-black/10 md:from-black/72 md:via-black/28 md:to-black/5 group-hover:from-black/80 group-hover:via-black/40 group-hover:to-black/10 transition duration-500"></div>

          <!-- Contenido -->
          <div class="relative z-10 h-full flex flex-col justify-end p-6 md:p-7 lg:p-8 text-white">
            <h3 class="text-xl md:text-[1.6rem] font-semibold leading-[1.05] [text-shadow:0_1px_2px_rgba(0,0,0,0.45)]">
              {card.title}
            </h3>

            <p class="mt-3 text-sm md:text-[0.98rem] leading-relaxed text-white/90 max-w-[30ch] [text-shadow:0_1px_2px_rgba(0,0,0,0.55)]">
              {card.description}
            </p>

            <div class="mt-5 text-[11px] md:text-xs uppercase tracking-[0.22em] text-white/75 [text-shadow:0_1px_2px_rgba(0,0,0,0.45)]">
              {card.tags}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>