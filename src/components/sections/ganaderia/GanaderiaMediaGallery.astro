---
import mcormickImg from "@/assets/agricultura/mcormick2.jpg";
import deutzImg from "@/assets/agricultura/deutz.jpg";
---

<section class="section-shell bg-white">
  <div class="section-inner">

    <div class="max-w-2xl">
      <p class="eyebrow mb-3">
        Campo y trabajo real
      </p>

      <h2 class="section-title">
        Día a día en la explotación
      </h2>

      <p class="section-copy mt-4">
        Imágenes y vídeos del trabajo de campaña, la maquinaria y el ritmo real del día a día.
      </p>
    </div>

    <div class="mt-10 grid md:grid-cols-2 lg:grid-cols-4 gap-6">

      <!-- Videos (se quedan en public) -->
      <video
        class="rounded-3xl h-64 w-full object-cover bg-black"
        src="/reels/cosechando.mp4"
        autoplay
        muted
        loop
        playsinline
      ></video>

      <video
        class="rounded-3xl h-64 w-full object-cover bg-black"
        src="/reels/cosechadora-remolque.mp4"
        autoplay
        muted
        loop
        playsinline
      ></video>

      <!-- Imágenes (desde src/assets) -->
      <img
        src={mcormickImg.src}
        alt="Tractor McCormick en la explotación"
        class="rounded-3xl h-64 w-full object-cover"
      />

      <img
        src={deutzImg.src}
        alt="Tractor Deutz en la explotación"
        class="rounded-3xl h-64 w-full object-cover"
      />

    </div>

  </div>
</section>