---
import { Image } from "astro:assets";
import vacas from "@/assets/ganaderia/vacas.jpg";
import type { Locale } from "../../../i18n";

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? "es";

const copy = {
  es: {
    imageAlt: "Ganado en Iturribero",
    eyebrow: "Nuestra forma de trabajar",
    title: ["Bienestar primero.", "Manejo responsable, sin atajos."],
    description:
      "La ganader\u00EDa se sostiene en el seguimiento diario, en la observaci\u00F3n y en una forma de decidir que pone por delante al animal, el entorno y la continuidad.",
    sideTitle: ["Estar encima de lo importante", "marca la diferencia en el d\u00EDa a d\u00EDa."],
    sideDescription:
      "Observar, anticiparse y cuidar los detalles forma parte de una manera de trabajar cercana, constante y m\u00E1s exigente de lo que parece desde fuera.",
    cards: [
      {
        title: "Seguimiento diario",
        description:
          "Revisar, observar y anticiparse forma parte del trabajo diario y condiciona muchas decisiones peque\u00F1as.",
      },
      {
        title: "Bienestar animal",
        description:
          "El manejo responsable no es un eslogan: se traduce en presencia, cuidado y criterio continuado.",
      },
      {
        title: "Alimentaci\u00F3n conectada",
        description:
          "Parte de la alimentaci\u00F3n procede de nuestros cultivos, reforzando la conexi\u00F3n entre el campo y el ganado.",
      },
    ],
  },
  eu: {
    imageAlt: "Azienda Iturriberon",
    eyebrow: "Lan egiteko modua",
    title: ["Ongizatea lehenik.", "Ardurazko kudeaketa, lasterbiderik gabe."],
    description:
      "Ardurazko kudeaketa, lasterbiderik gabe. Gure abeltzaintza eguneroko behaketan oinarritzen da: animalia, ingurunea eta jarraitutasuna lehenesten dituen erabaki-hartzea.",
    sideTitle: ["Garrantzitsuaren gainean egoteak", "markatzen du aldea."],
    sideDescription:
      "Behatzea, aurre hartzea eta xehetasunak zaintzea; horixe da gure eguneroko zaintza hurbil eta zorrotzaren muina.",
    cards: [
      {
        title: "Eguneroko jarraipena",
        description:
          "Begiratu, behatu eta aurrea hartu. Horrela hartzen ditugu eguneroko erabaki txiki baina garrantzitsuak.",
      },
      {
        title: "Animalien ongizatea",
        description:
          "Kudeaketa arduratsua ez da lelo bat; presentzia, zaintza eta etengabeko irizpidea da.",
      },
      {
        title: "Elikadura lotua",
        description:
          "Jaten dutenaren zati bat gure laboreetatik dator, lurraren eta abereen arteko lotura estutuz.",
      },
    ],
  },
}[locale];
---

<section class="section-shell bg-white pt-2">
  <div class="section-inner">
    <div class="relative">
      <div class="relative h-70 overflow-hidden rounded-4xl shadow-xl ring-1 ring-gray-200 md:h-105">
        <Image
          src={vacas}
          alt={copy.imageAlt}
          class="absolute inset-0 h-full w-full object-cover"
          sizes="100vw"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-linear-to-t from-black/24 via-black/4 to-transparent"></div>
      </div>

      <div class="relative z-10 -mt-8 max-w-xxl rounded-[1.75rem] border border-gray-100 bg-white/95 p-6 shadow-2xl backdrop-blur-md md:absolute md:right-10 md:-bottom-22 md:mt-0 md:p-8">
        <p class="eyebrow mb-4">
          {copy.eyebrow}
        </p>

        <h2 class="section-title">
          {copy.title[0]}
          <span class="block">{copy.title[1]}</span>
        </h2>

        <p class="section-copy mt-5 max-w-lg">
          {copy.description}
        </p>
      </div>
    </div>

    <div class="pt-12 md:pt-24">
      <div class="mb-10 max-w-xl rounded-r-2xl border-l-4 border-blue-200 bg-blue-50/40 pl-6">
        <h3 class="title-md text-gray-900">
          {copy.sideTitle[0]}
          <span class="block">{copy.sideTitle[1]}</span>
        </h3>

        <p class="body-copy mt-4">
          {copy.sideDescription}
        </p>
      </div>

      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {copy.cards.map((card) => (
          <div class="group relative overflow-hidden rounded-3xl bg-gray-900 p-6 text-white ring-1 ring-gray-800/10 transition duration-500 hover:-translate-y-1 hover:shadow-2xl">
            <div class="absolute inset-0 bg-linear-to-t from-white/5 to-transparent opacity-0 transition group-hover:opacity-100"></div>
            <p class="font-semibold">
              {card.title}
            </p>
            <p class="mt-3 text-white/75">
              {card.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
