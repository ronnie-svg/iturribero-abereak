---
import { Image } from "astro:assets";
import hero from "@/assets/ganaderia/vaca_primer-plano.jpg";
import type { Locale } from "../../../i18n";

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? "es";

const copy = {
  es: {
    alt: "Ganadería de Iturribero Abereak en Durana, Álava",
    title: ["Vacas de carne.", "Cuidado diario."],
    description:
      "Explotación familiar en Durana, Álava, con seguimiento constante, bienestar animal y una manera de trabajar cercana al ritmo real del campo.",
    panels: [
      {
        title: "Seguimiento",
        text: "Observar, anticiparse y estar encima de lo importante.",
        tone: "light",
      },
      {
        title: "Bienestar",
        text: "Manejo responsable y atencion constante al animal.",
        tone: "light",
      },
      {
        title: "Explotación",
        text: "Un tamano cercano permite trabajar con calma y control.",
        tone: "dark",
      },
    ],
  },
  eu: {
    alt: "Iturribero Abereakeko abeltzaintza Duranan, Araban",
    title: ["Haragi-behiak,", "eguneroko zaintzapean."],
    description:
      "Duranako familia-ustiategi honetan, animalien ongizatea eta jarraipen etengabea dira gure ardatzak. Landaren benetako erritmora hurbiltzen den lan egiteko modua dugu gurea.",
    panels: [
      {
        title: "Jarraipena",
        text: "Behatu, aurreratu eta garrantzitsuaren gainean egon.",
        tone: "light",
      },
      {
        title: "Ongizatea",
        text: "Ardurazko kudeaketa eta animaliari etengabeko arreta.",
        tone: "light",
      },
      {
        title: "Ustiapena",
        text: "Giza eskalako tamainak lasaitasunez eta kontrolarekin lan egitea ahalbidetzen du.",
        tone: "dark",
      },
    ],
  },
}[locale];
---

<section class="relative isolate overflow-hidden border-b border-stone-200 bg-stone-100 text-white">
  <div class="absolute inset-0">
    <Image
      src={hero}
      alt={copy.alt}
      class="h-full w-full object-cover object-center"
      sizes="100vw"
      loading="eager"
      priority
    />
    <div class="absolute inset-0 bg-black/18"></div>
  </div>

  <div class="relative mx-auto flex min-h-[58vh] max-w-7xl items-end px-6 py-14 md:min-h-[62vh] md:px-8 md:py-16">
    <div class="grid w-full gap-14 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:items-end">
      <div class="max-w-2xl">
        <h1 class="text-5xl font-semibold leading-[0.96] tracking-[-0.045em] text-white [text-shadow:0_10px_30px_rgba(0,0,0,0.35)] sm:text-6xl lg:text-7xl">
          {copy.title[0]}
          <br />
          {copy.title[1]}
        </h1>

        <p class="mt-6 max-w-xl text-base leading-7 text-white/88 [text-shadow:0_6px_20px_rgba(0,0,0,0.3)] md:text-lg">
          {copy.description}
        </p>
      </div>

      <div class="lg:justify-self-end lg:max-w-xl">
        <div class="grid gap-px overflow-hidden rounded-[2rem] border border-stone-300 bg-stone-300 shadow-[0_30px_80px_-56px_rgba(28,25,23,0.45)] md:grid-cols-3">
          {copy.panels.map((panel) => (
            <article class={panel.tone === "dark" ? "bg-stone-950 p-5 text-white" : "bg-white/82 p-5 backdrop-blur-sm"}>
              <p class={panel.tone === "dark" ? "text-xs uppercase tracking-[0.28em] text-amber-200/90" : "text-xs uppercase tracking-[0.28em] text-stone-500"}>
                {panel.title}
              </p>
              <p class={panel.tone === "dark" ? "mt-3 text-lg font-semibold leading-tight" : "mt-3 text-lg font-semibold leading-tight text-stone-950"}>
                {panel.text}
              </p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
