---
const items = [
  {
    title: "Quiénes somos",
    href: "/quienes-somos",
    label: "Descubrir",
  },
  {
    title: "Ganadería",
    href: "/ganaderia",
    label: "Ver más",
  },
  {
    title: "Agricultura",
    href: "/agricultura",
    label: "Conocer más",
  },
  {
    title: "Contacto",
    href: "/contacto",
    label: "Contactar",
  },
];
---

<section class="feature-links" aria-label="Accesos principales">
  <div class="feature-links__overlay"></div>

  <div class="feature-links__inner">
    {items.map((item) => (
      <a class="feature-card" href={item.href}>
        <h3>{item.title}</h3>
        <span>
          {item.label}
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
            width="18"
            height="18"
          >
            <path
              d="M5 12h14M13 5l7 7-7 7"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </span>
      </a>
    ))}
  </div>
</section>

<style>
  .feature-links {
    position: relative;
    min-height: 560px;
    display: flex;
    align-items: end;
    background-image: url("/images/home/campo-iturribero.jpg");
    background-size: cover;
    background-position: center;
    overflow: hidden;
    isolation: isolate;
  }

  .feature-links__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, rgba(0, 0, 0, 0.55), rgba(0, 0, 0, 0.15) 45%, rgba(0, 0, 0, 0.08));
    z-index: -1;
  }

  .feature-links__inner {
    width: min(1200px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 3rem 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .feature-card {
    color: white;
    text-decoration: none;
    padding: 1.5rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.28);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      opacity 180ms ease;
  }

  .feature-card:hover,
  .feature-card:focus-visible {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.8);
    opacity: 1;
  }

  .feature-card h3 {
    margin: 0 0 1rem;
    font-size: clamp(1.7rem, 2.3vw, 2.6rem);
    line-height: 1.02;
    font-weight: 800;
    max-width: 11ch;
  }

  .feature-card span {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
  }

  @media (max-width: 960px) {
    .feature-links {
      min-height: 620px;
      align-items: end;
    }

    .feature-links__inner {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .feature-links {
      min-height: auto;
    }

    .feature-links__inner {
      grid-template-columns: 1fr;
      padding: 2rem 0;
      gap: 0.5rem;
    }

    .feature-card {
      padding: 1.1rem 0;
    }

    .feature-card h3 {
      max-width: none;
      font-size: 2rem;
    }
  }
</style>